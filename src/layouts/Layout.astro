---
import '../styles/global.css';
import { uiTranslations } from '../utils/pokemon';

interface Props {
	title?: string;
    description?: string;
    lang?: string;
    image?: string;
}

const { 
    title = "Pokepedia", 
    description = "Tu enciclopedia Pokémon técnica y definitiva.", 
    lang = "es",
    image = "/pokeball.png" 
} = Astro.props;

const siteUrl = "https://pokepedia.app";
const finalImageUrl = image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`;

const currentPath = Astro.url.pathname;
const currentSearch = Astro.url.search;
const otherLang = lang === 'es' ? 'en' : 'es';
let otherLangPath = currentPath.replace(`/${lang}`, `/${otherLang}`) + currentSearch;
if (otherLangPath.startsWith('?')) otherLangPath = `/${otherLang}` + otherLangPath;

// Aplicar caché si está disponible en locals
if (Astro.locals.cacheControl) {
    Astro.response.headers.set('Cache-Control', Astro.locals.cacheControl);
}
---

<!doctype html>
<html lang={lang} prefix="og: https://ogp.me/ns#">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- Google tag (gtag.js) -->
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-J7Z6HJMYWD"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());

          gtag('config', 'G-J7Z6HJMYWD');
        </script>

        <link rel="preconnect" href="https://pokeapi.co" crossorigin>
        <link rel="preconnect" href="https://raw.githubusercontent.com" crossorigin>
        <link rel="preconnect" href="https://play.pokemonshowdown.com" crossorigin>
        <link rel="dns-prefetch" href="https://pokeapi.co">
        <link rel="dns-prefetch" href="https://play.pokemonshowdown.com">
        
        <link rel="icon" type="image/png" href="/pokeball.png?v=1">
        <link rel="shortcut icon" href="/pokeball.png?v=1">
        <link rel="apple-touch-icon" href="/pokeball.png?v=1">
        <link rel="manifest" href="/manifest.json">
        <meta name="theme-color" content="#10b981">
		<meta name="generator" content={Astro.generator} />
        
		<title>{title === 'Pokepedia' ? 'Pokepedia | The Ultimate Technical Pokémon Encyclopedia & Type Calculator' : `${title} | Pokepedia`}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content="Pokemon, Pokedex, Pokepedia, Type Calculator, Weakness Chart, Smogon, Showdown, competitive Pokemon, Pokemon stats, Gen 9, Pokemon Scarlet Violet, Type Coverage" />
        <meta name="author" content="Xarli11" />
        <link rel="canonical" href={Astro.url} />
        
        <!-- Multilanguage SEO -->
        <link rel="alternate" hreflang="es" href={new URL(currentPath.replace(`/${lang}`, '/es'), siteUrl)} />
        <link rel="alternate" hreflang="en" href={new URL(currentPath.replace(`/${lang}`, '/en'), siteUrl)} />
        <link rel="alternate" hreflang="x-default" href={new URL(currentPath.replace(`/${lang}`, '/es'), siteUrl)} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title === 'Pokepedia' ? 'Pokepedia | The Ultimate Technical Pokémon Encyclopedia' : `${title} | Pokepedia`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={finalImageUrl} />
        <meta property="og:image:secure_url" content={finalImageUrl} />
        <meta property="og:image:alt" content={title} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Pokepedia" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={Astro.url} />
        <meta name="twitter:title" content={title === 'Pokepedia' ? 'Pokepedia | The Ultimate Technical Pokémon Encyclopedia' : `${title} | Pokepedia`} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={finalImageUrl} />
        <meta name="twitter:image:alt" content={title} />
        
        <!-- Structured Data (Schema.org) -->
        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "WebApplication",
          "name": "Pokepedia",
          "url": "https://pokepedia.app",
          "description": "The Ultimate Technical Pokémon Encyclopedia with competitive integration, technical stats, and meta analysis.",
          "applicationCategory": "GameApplication",
          "operatingSystem": "Any",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          },
          "featureList": "Competitive integration, Smogon Tiers, Technical Stats, Evolutionary Chains, Move & Ability Dex"
        }
        </script>
        
        <script is:inline define:vars={{ lang }}>
            const savedTheme = localStorage.getItem('theme');
            const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            const theme = savedTheme || systemTheme;
            if (theme === 'dark') document.documentElement.classList.add('dark');
        </script>
	</head>
	<body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 min-h-screen font-sans antialiased flex flex-col transition-colors duration-500">
        <header class="sticky top-0 z-50 w-full bg-white/80 dark:bg-slate-950/80 backdrop-blur-xl border-b border-slate-200/50 dark:border-slate-800 transition-all duration-300">
            <div class="container mx-auto px-4 py-3 flex items-center justify-between">
                <!-- Logo Edition -->
                <a href={`/${lang}`} class="flex items-center gap-2 md:gap-4 group no-underline">
                    <div class="relative w-10 h-10 md:w-12 md:h-12 flex items-center justify-center shrink-0">
                        <!-- Hexágono de Fondo -->
                        <div class="absolute inset-0 bg-slate-900 dark:bg-emerald-500/10 border-2 border-emerald-500 rounded-xl rotate-45 group-hover:rotate-90 transition-all duration-700 shadow-[0_0_15px_rgba(16,185,129,0.2)]"></div>
                        
                        <!-- Poké-Core SVG -->
                        <svg class="relative w-5 h-5 md:w-6 md:h-6 text-emerald-500 dark:text-emerald-400 z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M2 12h20"/>
                            <circle cx="12" cy="12" r="3" fill="currentColor"/>
                            <path d="M12 2a10 10 0 0 1 10 10" class="opacity-30 group-hover:opacity-100 group-hover:animate-pulse transition-opacity"/>
                        </svg>
                    </div>

                    <div class="flex flex-col">
                        <div class="flex items-baseline gap-0.5">
                            <span class="text-2xl md:text-3xl font-[1000] tracking-tighter text-slate-900 dark:text-white uppercase leading-none">POKE</span>
                            <span class="text-2xl md:text-3xl font-thin tracking-widest text-emerald-500 uppercase leading-none">pedia</span>
                        </div>
                        <div class="hidden sm:flex items-center gap-2 mt-1.5">
                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                            <span class="text-[9px] font-mono font-bold text-slate-400 dark:text-slate-500 tracking-[0.2em] uppercase">
                                {lang === 'es' ? '[ ESTADO_DEX: ACTIVO • GEN_IX ]' : '[ DEX_STATUS: ACTIVE • GEN_IX ]'}
                            </span>
                        </div>
                    </div>
                </a>
                
                <div class="flex items-center gap-3 md:gap-6">
                    <nav class="hidden md:flex gap-8 text-sm font-bold text-slate-600 dark:text-slate-400">
                        <a href={`/${lang}`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Pokedex</a>
                        <a href={`/${lang}/movimientos`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                            {uiTranslations[lang]?.moves || uiTranslations.es.moves}
                        </a>
                        <a href={`/${lang}/habilidades`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                            {uiTranslations[lang]?.abilities || uiTranslations.es.abilities}
                        </a>
                        <a href={`/${lang}/objetos`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">
                            {uiTranslations[lang]?.items || uiTranslations.es.items}
                        </a>
                    </nav>

                    <div class="flex items-center gap-2 md:gap-4 md:border-l border-slate-200 dark:border-slate-800 md:pl-6">
                        <!-- Buscador Global -->
                        <button 
                            id="global-search-trigger"
                            class="flex items-center gap-3 px-3 py-1.5 md:px-4 md:py-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 hover:bg-emerald-500 hover:text-white transition-all group border border-transparent hover:border-emerald-400/30"
                            title={lang === 'es' ? 'Buscar Pokémon ( / )' : 'Search Pokémon ( / )'}
                        >
                            <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                            <span class="hidden lg:block text-[10px] font-black uppercase tracking-widest">{lang === 'es' ? 'Buscar' : 'Search'}</span>
                            <span class="hidden lg:block px-1.5 py-0.5 rounded bg-slate-200 dark:bg-slate-700 text-[8px] font-mono group-hover:bg-emerald-400 group-hover:text-emerald-900 transition-colors">/</span>
                        </button>

                        <!-- SWITCH CON ICONOS SVG VISIBLES -->
                        <button 
                            id="theme-switch"
                            class="relative inline-flex h-8 w-14 md:h-9 md:w-16 items-center rounded-full bg-slate-200 dark:bg-slate-800 transition-colors cursor-pointer shadow-inner group shrink-0"
                            aria-label="Toggle Theme"
                        >
                            <div class="absolute left-1 h-6 w-6 md:h-7 md:w-7 rounded-full bg-white dark:bg-slate-700 shadow-lg transform transition-all duration-300 flex items-center justify-center z-10 dark:translate-x-6 md:dark:translate-x-7">
                                <!-- Icono Sol -->
                                <svg class="h-3 w-3 md:h-4 md:w-4 text-amber-500 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a3 3 0 100 6 3 3 0 000-6z" />
                                </svg>
                                <!-- Icono Luna -->
                                <svg class="h-3 w-3 md:h-4 md:w-4 text-emerald-400 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                                </svg>
                            </div>
                        </button>

                        <!-- Pokémon Aleatorio -->
                        <button 
                            id="random-pokemon-btn"
                            class="h-8 w-8 md:h-9 md:w-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-emerald-500 hover:text-white transition-all group shrink-0"
                            title={lang === 'es' ? 'Pokémon Aleatorio' : 'Random Pokémon'}
                        >
                            <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:rotate-180 transition-transform duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><circle cx="15.5" cy="15.5" r="1.5"/><circle cx="15.5" cy="8.5" r="1.5"/><circle cx="8.5" cy="15.5" r="1.5"/><circle cx="12" cy="12" r="1.5"/>
                            </svg>
                        </button>

                        <!-- Favoritos -->
                        <a 
                            href={`/${lang}?gen=favorites`}
                            class="h-8 w-8 md:h-9 md:w-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-rose-500 hover:text-white transition-all group shrink-0"
                            title={uiTranslations[lang]?.favorites || uiTranslations.es.favorites}
                        >
                            <svg class="w-4 h-4 md:w-5 md:h-5 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path>
                            </svg>
                        </a>

                        <a href={otherLangPath} class="h-8 px-3 md:h-9 md:px-4 flex items-center rounded-xl bg-slate-100 dark:bg-slate-800 text-[9px] md:text-[10px] font-black uppercase tracking-widest transition-all hover:bg-emerald-500 hover:text-white dark:hover:bg-emerald-500 shrink-0">
                            {otherLang}
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <main class="container mx-auto px-4 pt-12 pb-12 flex-grow">
		    <slot />
        </main>

        <nav class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50 w-[95%] max-w-md bg-white/80 dark:bg-slate-900/80 backdrop-blur-2xl border border-slate-200 dark:border-slate-800 rounded-[2.5rem] shadow-2xl shadow-black/20 px-6 py-3 flex items-center justify-between transition-all duration-300">
            <a href={`/${lang}`} class={`flex flex-col items-center gap-1 group ${currentPath === `/${lang}` || (currentPath === '/' && lang === 'es') ? 'text-emerald-500' : 'text-slate-400'}`}>
                <svg class="w-5 h-5 transition-transform group-active:scale-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><circle cx="12" cy="12" r="3" fill="currentColor"/>
                </svg>
                <span class="text-[9px] font-black uppercase tracking-widest">Dex</span>
            </a>
            <a href={`/${lang}/movimientos`} class={`flex flex-col items-center gap-1 group ${currentPath.includes('/movimientos') ? 'text-emerald-500' : 'text-slate-400'}`}>
                <svg class="w-5 h-5 transition-transform group-active:scale-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
                <span class="text-[9px] font-black uppercase tracking-widest">{lang === 'es' ? 'Movs' : 'Moves'}</span>
            </a>

            <!-- Botón Central de Favoritos (Móvil) -->
            <a href={`/${lang}?gen=favorites`} class={`flex flex-col items-center gap-1 group ${Astro.url.searchParams.get('gen') === 'favorites' ? 'text-rose-500' : 'text-slate-400'}`}>
                <div class={`p-2 rounded-2xl ${Astro.url.searchParams.get('gen') === 'favorites' ? 'bg-rose-500/10' : ''}`}>
                    <svg class="w-6 h-6 transition-transform group-active:scale-125" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path>
                    </svg>
                </div>
            </a>

            <a href={`/${lang}/habilidades`} class={`flex flex-col items-center gap-1 group ${currentPath.includes('/habilidades') ? 'text-emerald-500' : 'text-slate-400'}`}>
                <svg class="w-5 h-5 transition-transform group-active:scale-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
                <span class="text-[9px] font-black uppercase tracking-widest">{lang === 'es' ? 'Habs' : 'Abil'}</span>
            </a>
            <a href={`/${lang}/objetos`} class={`flex flex-col items-center gap-1 group ${currentPath.includes('/objetos') ? 'text-emerald-500' : 'text-slate-400'}`}>
                <svg class="w-5 h-5 transition-transform group-active:scale-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
                <span class="text-[9px] font-black uppercase tracking-widest">{lang === 'es' ? 'Obj' : 'Item'}</span>
            </a>
        </nav>

        <!-- Buscador Global Modal -->
        <div id="global-search-modal" class="fixed inset-0 z-[100] hidden items-start justify-center pt-24 px-4 backdrop-blur-2xl bg-slate-950/40 transition-all duration-300">
            <div class="absolute inset-0" id="modal-overlay"></div>
            <div class="relative w-full max-w-2xl bg-white dark:bg-slate-900 rounded-[3rem] shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="modal-content">
                <div class="p-6 border-b border-slate-100 dark:border-slate-800">
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none text-slate-400">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input 
                            type="text" 
                            id="global-search-input" 
                            placeholder={lang === 'es' ? 'Busca cualquier Pokémon...' : 'Search any Pokémon...'}
                            autocomplete="off"
                            class="w-full pl-14 pr-6 py-5 bg-transparent text-xl font-bold text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none"
                        />
                        <div class="absolute inset-y-0 right-0 pr-5 flex items-center">
                            <span class="px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 text-[10px] font-black text-slate-400 tracking-tighter uppercase">ESC</span>
                        </div>
                    </div>
                </div>
                <div id="global-search-results" class="max-h-[500px] overflow-y-auto divide-y divide-slate-50 dark:divide-slate-800/50">
                    <!-- JS Results -->
                </div>
                <div class="px-10 py-6 bg-slate-50/50 dark:bg-slate-950/20 border-t border-slate-100 dark:border-slate-800 flex justify-between items-center text-[9px] font-black uppercase tracking-widest text-slate-400">
                    <div class="flex gap-8">
                        <span class="flex items-center gap-3"><kbd class="px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">↵</kbd> {lang === 'es' ? 'Seleccionar' : 'Select'}</span>
                        <span class="flex items-center gap-3"><kbd class="px-2 py-1 rounded bg-slate-100 dark:bg-slate-800 border border-slate-200 dark:border-slate-700">↑↓</kbd> {lang === 'es' ? 'Navegar' : 'Navigate'}</span>
                    </div>
                    <span>Pokepedia Search v2.0</span>
                </div>
            </div>
        </div>

        <button 
            id="back-to-top"
            class="fixed bottom-28 right-6 sm:bottom-8 sm:right-8 z-[100] h-10 w-10 sm:h-12 sm:w-12 rounded-2xl bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border border-slate-200 dark:border-slate-800 text-slate-500 dark:text-slate-400 shadow-2xl transition-all duration-300 translate-y-32 opacity-0 hover:scale-110 active:scale-95 group"
            title="Volver Arriba"
        >
            <svg class="w-5 h-5 sm:w-6 sm:h-6 mx-auto group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7"></path>
            </svg>
        </button>

        <footer class="mt-8 pb-32 md:pb-12 px-4">
            <div class="container mx-auto">
                <div class="relative bg-white dark:bg-slate-900/50 backdrop-blur-xl border border-slate-200 dark:border-slate-800 rounded-[3rem] p-12 md:p-16 overflow-hidden shadow-sm">
                    <!-- Elementos Decorativos Bento -->
                    <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl -mr-32 -mt-32"></div>
                    <div class="absolute bottom-0 left-0 w-64 h-64 bg-emerald-500/5 rounded-full blur-3xl -ml-32 -mb-32"></div>

                    <div class="relative flex flex-col items-center">
                        <!-- Botón de Apoyo Bento Style -->
                        <div class="mb-12">
                            <a 
                                href="https://buymeacoffee.com/xarli11" 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-4 px-6 py-3 rounded-2xl bg-slate-50 dark:bg-slate-800/50 border border-slate-100 dark:border-slate-700 text-amber-600 dark:text-amber-400 font-bold text-sm hover:scale-105 transition-all duration-300 group"
                            >
                                <svg class="w-5 h-5 group-hover:rotate-12 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
                                    <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
                                    <line x1="6" y1="1" x2="6" y2="4"></line>
                                    <line x1="10" y1="1" x2="10" y2="4"></line>
                                    <line x1="14" y1="1" x2="14" y2="4"></line>
                                </svg>
                                <span class="tracking-tight">{uiTranslations[lang]?.support_project || uiTranslations.es.support_project}</span>
                            </a>
                        </div>

                        <!-- Logo en Footer -->
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-10 h-10 relative flex items-center justify-center">
                                <div class="absolute inset-0 bg-slate-900 dark:bg-emerald-500/10 border-2 border-emerald-500 rounded-xl rotate-45 group-hover:rotate-90 transition-all duration-700"></div>
                                <svg class="relative w-5 h-5 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><circle cx="12" cy="12" r="3" fill="currentColor"/>
                                </svg>
                            </div>
                            <span class="text-2xl font-black tracking-tighter text-slate-900 dark:text-white uppercase">POKE<span class="font-thin text-emerald-500">pedia</span></span>
                        </div>

                        <div class="text-center space-y-4">
                            <p class="text-slate-900 dark:text-white font-black text-xl tracking-tight italic">
                                © 2026 Pokepedia <span class="text-emerald-500 mx-2">•</span> Data up to Gen 9
                            </p>
                            <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-4">
                                <p class="text-slate-500 dark:text-slate-400 text-sm font-medium tracking-wide">
                                    Designed & Crafted by <span class="text-emerald-600 dark:text-emerald-400 font-black underline decoration-emerald-500/20 underline-offset-8">Xarli11</span>
                                </p>
                                <span class="hidden md:block h-1 w-1 rounded-full bg-slate-300 dark:bg-slate-700"></span>
                                <p class="text-[10px] font-mono font-bold text-slate-400 dark:text-slate-600 uppercase tracking-widest">
                                    {lang === 'es' ? '[ INVESTIGACIÓN_ACTIVA ]' : '[ RESEARCH_ACTIVE ]'}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </footer>

        <script is:inline define:vars={{ lang }}>
            function initTheme() {
                const btn = document.getElementById('theme-switch');
                if (!btn) return;
                btn.onclick = () => {
                    const isDark = document.documentElement.classList.toggle('dark');
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                };
            }

            window.toggleFavorite = (pokemonName) => {
                const favorites = JSON.parse(localStorage.getItem('pokepedia_favorites') || '[]');
                const index = favorites.indexOf(pokemonName);
                let action = 'add';
                
                if (index > -1) {
                    favorites.splice(index, 1);
                    action = 'remove';
                } else {
                    favorites.push(pokemonName);
                }
                
                localStorage.setItem('pokepedia_favorites', JSON.stringify(favorites));
                document.dispatchEvent(new CustomEvent('favorites-updated'));

                // Google Analytics Event Tracking
                if (typeof gtag === 'function') {
                    gtag('event', 'pokemon_favorite', {
                        'pokemon_name': pokemonName,
                        'action': action
                    });
                }
            };

            function initRandom() {
                const btn = document.getElementById('random-pokemon-btn');
                if (!btn) return;
                btn.onclick = async () => {
                    btn.disabled = true;
                    btn.classList.add('animate-pulse', 'opacity-50');
                    const randomId = Math.floor(Math.random() * 1025) + 1;
                    try {
                        const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${randomId}`);
                        const data = await res.json();
                        window.location.href = `/${lang}/pokemon/${data.name}`;
                    } catch (e) {
                        btn.disabled = false;
                        btn.classList.remove('animate-pulse', 'opacity-50');
                    }
                };
            }

            function initBackToTop() {
                const btn = document.getElementById('back-to-top');
                if (!btn) return;
                
                window.onscroll = () => {
                    if (window.scrollY > 500) {
                        btn.classList.remove('translate-y-32', 'opacity-0');
                        btn.classList.add('translate-y-0', 'opacity-100');
                    } else {
                        btn.classList.add('translate-y-32', 'opacity-0');
                        btn.classList.remove('translate-y-0', 'opacity-100');
                    }
                };

                btn.onclick = () => {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                };
            }

            initTheme();
            initRandom();
            initBackToTop();

            function initGlobalSearch() {
                const trigger = document.getElementById('global-search-trigger');
                const modal = document.getElementById('global-search-modal');
                const input = document.getElementById('global-search-input');
                const results = document.getElementById('global-search-results');
                const overlay = document.getElementById('modal-overlay');
                const content = document.getElementById('modal-content');
                let selectedIndex = -1;

                function toggleModal(show) {
                    if (show) {
                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        setTimeout(() => {
                            content.classList.remove('scale-95', 'opacity-0');
                            content.classList.add('scale-100', 'opacity-100');
                            input.focus();
                        }, 10);
                        document.body.style.overflow = 'hidden';
                    } else {
                        content.classList.add('scale-95', 'opacity-0');
                        content.classList.remove('scale-100', 'opacity-100');
                        setTimeout(() => {
                            modal.classList.add('hidden');
                            modal.classList.remove('flex');
                        }, 300);
                        document.body.style.overflow = '';
                        input.value = '';
                        results.innerHTML = '';
                    }
                }

                trigger?.addEventListener('click', () => toggleModal(true));
                overlay?.addEventListener('click', () => toggleModal(false));

                document.addEventListener('keydown', (e) => {
                    if (e.key === '/' && document.activeElement !== input) {
                        e.preventDefault();
                        toggleModal(true);
                    }
                    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
                        toggleModal(false);
                    }

                    if (!modal.classList.contains('hidden')) {
                        const items = results.querySelectorAll('a');
                        if (e.key === 'ArrowDown') {
                            e.preventDefault();
                            selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
                            updateSelection(items);
                        } else if (e.key === 'ArrowUp') {
                            e.preventDefault();
                            selectedIndex = Math.max(selectedIndex - 1, -1);
                            updateSelection(items);
                        } else if (e.key === 'Enter' && selectedIndex >= 0) {
                            e.preventDefault();
                            items[selectedIndex].click();
                        }
                    }
                });

                function updateSelection(items) {
                    items.forEach((item, idx) => {
                        if (idx === selectedIndex) {
                            item.classList.add('bg-emerald-50', 'dark:bg-emerald-950/20', 'border-emerald-500/50');
                            item.scrollIntoView({ block: 'nearest' });
                        } else {
                            item.classList.remove('bg-emerald-50', 'dark:bg-emerald-950/20', 'border-emerald-500/50');
                        }
                    });
                }

                let searchTimeout;
                input?.addEventListener('input', () => {
                    const query = input.value.trim().toLowerCase();
                    clearTimeout(searchTimeout);
                    if (query.length < 2) {
                        results.innerHTML = '';
                        return;
                    }

                    searchTimeout = setTimeout(async () => {
                        results.innerHTML = Array(3).fill(0).map(() => `
                            <div class="p-6 animate-pulse flex items-center gap-4">
                                <div class="w-12 h-12 bg-slate-100 dark:bg-slate-800 rounded-2xl"></div>
                                <div class="space-y-2"><div class="w-24 h-4 bg-slate-100 dark:bg-slate-800 rounded"></div><div class="w-12 h-2 bg-slate-100 dark:bg-slate-800 rounded"></div></div>
                            </div>
                        `).join('');

                        try {
                            const res = await fetch(`/api/suggestions?q=${encodeURIComponent(query)}`);
                            const matches = await res.json();
                            selectedIndex = -1;

                            if (matches.length > 0) {
                                results.innerHTML = matches.map((p, idx) => {
                                    const spriteUrl = p.sprite || `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${p.id}.png`;
                                    const isVariety = p.id > 10000;
                                    return `
                                        <a href="/${lang}/pokemon/${p.name}" class="flex items-center gap-5 px-6 py-4 hover:bg-emerald-50 dark:hover:bg-emerald-950/20 border-l-4 border-transparent transition-all group">
                                            <div class="w-12 h-12 bg-slate-50 dark:bg-slate-900/50 rounded-2xl flex items-center justify-center p-1 border border-slate-100 dark:border-slate-800 transition-colors group-hover:bg-white dark:group-hover:bg-slate-800">
                                                <img src="${spriteUrl}" alt="${p.name}" class="w-full h-full object-contain drop-shadow-md" loading="lazy" onerror="this.src='/pokeball.png'; this.classList.add('opacity-20');">
                                            </div>
                                            <div class="flex flex-col">
                                                <span class="text-[10px] font-black text-slate-300 dark:text-slate-600">${isVariety ? (lang === 'es' ? 'FORMA ESPECIAL' : 'SPECIAL FORM') : '#' + p.id.toString().padStart(4, '0')}</span>
                                                <span class="text-slate-700 dark:text-slate-200 font-bold capitalize group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">${p.name.replace(/-/g, ' ')}</span>
                                            </div>
                                            <span class="ml-auto text-[9px] font-black text-slate-400 dark:text-slate-600 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0">${lang === 'es' ? 'Ver' : 'View'} →</span>
                                        </a>
                                    `;
                                }).join('');
                            } else {
                                results.innerHTML = `<div class="p-12 text-center text-slate-400 font-bold uppercase tracking-widest text-xs">${lang === 'es' ? 'Sin resultados' : 'No results found'}</div>`;
                            }
                        } catch (e) {
                            results.innerHTML = '';
                        }
                    }, 150);
                });
            }

            initGlobalSearch();

            document.addEventListener('astro:after-swap', () => {
                initTheme();
                initRandom();
                initBackToTop();
                initGlobalSearch();
            });
        </script>
	</body>
</html>
