---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { uiTranslations } from '../utils/pokemon';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
    description?: string;
    lang?: string;
    image?: string;
}

const { 
    title = "Pokepedia", 
    description = "Tu enciclopedia Pokémon técnica y definitiva.", 
    lang = "es",
    image = "/pokeball.png" 
} = Astro.props;

const siteUrl = "https://pokepedia.app";
const finalImageUrl = image.startsWith('http') ? image : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`;

const currentPath = Astro.url.pathname;
const currentSearch = Astro.url.search;
const otherLang = lang === 'es' ? 'en' : 'es';
let otherLangPath = currentPath.replace(`/${lang}`, `/${otherLang}`) + currentSearch;
if (otherLangPath.startsWith('?')) otherLangPath = `/${otherLang}` + otherLangPath;

// Aplicar caché si está disponible en locals
if (Astro.locals.cacheControl) {
    Astro.response.headers.set('Cache-Control', Astro.locals.cacheControl);
}
---

<!doctype html>
<html lang={lang} prefix="og: https://ogp.me/ns#">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
        
        <!-- Google Analytics 4 (GA4) -->
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-J7Z6HJMYWD"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());

          console.log("🔍 [Pokepedia] Inicializando GA4 con ID: G-J7Z6HJMYWD");

          gtag('config', 'G-J7Z6HJMYWD', {
            'debug_mode': true,
            'send_page_view': true,
            'cookie_flags': 'SameSite=None;Secure'
          });

          // Rastrear navegación SPA de Astro
          document.addEventListener('astro:after-swap', () => {
            console.log("🚀 [Pokepedia] Cambio de página detectado:", window.location.pathname);
            gtag('config', 'G-J7Z6HJMYWD', {
              'page_path': window.location.pathname,
              'debug_mode': true,
              'send_page_view': true
            });
          });
        </script>

        <link rel="preconnect" href="https://pokeapi.co" crossorigin>
        <link rel="preconnect" href="https://raw.githubusercontent.com" crossorigin>
        <link rel="preconnect" href="https://play.pokemonshowdown.com" crossorigin>
        <link rel="dns-prefetch" href="https://pokeapi.co">
        <link rel="dns-prefetch" href="https://play.pokemonshowdown.com">
        
        <link rel="icon" type="image/png" href="/pokeball.png?v=1">
        <link rel="shortcut icon" href="/pokeball.png?v=1">
        <link rel="apple-touch-icon" href="/pokeball.png?v=1">
        <link rel="manifest" href="/manifest.json">
        <meta name="theme-color" content="#10b981">
		<meta name="generator" content={Astro.generator} />
        
		<title>{title === 'Pokepedia' ? 'Pokepedia | The Ultimate Technical Pokémon Encyclopedia' : `${title} | Pokepedia`}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content="Pokemon, Pokedex, Pokepedia, Smogon, Showdown, competitive Pokemon, Pokemon stats, Gen 9, Pokemon Scarlet Violet" />
        <meta name="author" content="Xarli11" />
        <link rel="canonical" href={Astro.url} />
        
        <!-- Multilanguage SEO -->
        <link rel="alternate" hreflang="es" href={new URL(currentPath.replace(`/${lang}`, '/es'), siteUrl)} />
        <link rel="alternate" hreflang="en" href={new URL(currentPath.replace(`/${lang}`, '/en'), siteUrl)} />
        <link rel="alternate" hreflang="x-default" href={new URL(currentPath.replace(`/${lang}`, '/es'), siteUrl)} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title === 'Pokepedia' ? 'Pokepedia | The Ultimate Technical Pokémon Encyclopedia' : `${title} | Pokepedia`} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={finalImageUrl} />
        <meta property="og:image:secure_url" content={finalImageUrl} />
        <meta property="og:image:alt" content={title} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:site_name" content="Pokepedia Research Lab" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={Astro.url} />
        <meta name="twitter:title" content={title === 'Pokepedia' ? 'Pokepedia | The Ultimate Technical Pokémon Encyclopedia' : `${title} | Pokepedia`} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={finalImageUrl} />
        <meta name="twitter:image:alt" content={title} />
        
        <!-- Structured Data (Schema.org) -->
        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "WebApplication",
          "name": "Pokepedia",
          "url": "https://pokepedia.app",
          "description": "The Ultimate Technical Pokémon Encyclopedia with competitive integration, technical stats, and meta analysis.",
          "applicationCategory": "GameApplication",
          "operatingSystem": "Any",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
          },
          "featureList": "Competitive integration, Smogon Tiers, Technical Stats, Evolutionary Chains, Move & Ability Dex"
        }
        </script>
        
        <script is:inline define:vars={{ lang }}>
            const savedTheme = localStorage.getItem('theme');
            const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            const theme = savedTheme || systemTheme;
            if (theme === 'dark') document.documentElement.classList.add('dark');
        </script>
        
        <Analytics />
        <SpeedInsights />
        <ClientRouter />
	</head>
	<body class="bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 min-h-screen font-sans antialiased flex flex-col transition-colors duration-500">
        <header class="sticky top-0 z-50 w-full bg-white/80 dark:bg-slate-950/80 backdrop-blur-xl border-b border-slate-200/50 dark:border-slate-800 transition-all duration-300">
            <div class="container mx-auto px-4 py-3 flex items-center justify-between">
                <!-- Logo Research Lab Edition -->
                <a href={`/${lang}`} class="flex items-center gap-4 group no-underline">
                    <div class="relative w-12 h-12 flex items-center justify-center">
                        <!-- Hexágono de Fondo -->
                        <div class="absolute inset-0 bg-slate-900 dark:bg-emerald-500/10 border-2 border-emerald-500 rounded-xl rotate-45 group-hover:rotate-90 transition-all duration-700 shadow-[0_0_15px_rgba(16,185,129,0.2)]"></div>
                        
                        <!-- Poké-Core SVG -->
                        <svg class="relative w-6 h-6 text-emerald-500 dark:text-emerald-400 z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M2 12h20"/>
                            <circle cx="12" cy="12" r="3" fill="currentColor"/>
                            <path d="M12 2a10 10 0 0 1 10 10" class="opacity-30 group-hover:opacity-100 group-hover:animate-pulse transition-opacity"/>
                        </svg>
                    </div>

                    <div class="flex flex-col">
                        <div class="flex items-baseline gap-0.5">
                            <span class="text-3xl font-[1000] tracking-tighter text-slate-900 dark:text-white uppercase leading-none">POKE</span>
                            <span class="text-3xl font-thin tracking-widest text-emerald-500 uppercase leading-none">pedia</span>
                        </div>
                        <div class="flex items-center gap-2 mt-1.5">
                            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                            <span class="text-[9px] font-mono font-bold text-slate-400 dark:text-slate-500 tracking-[0.2em] uppercase">
                                {lang === 'es' ? '[ ESTADO_DEX: ACTIVO • GEN_IX ]' : '[ DEX_STATUS: ACTIVE • GEN_IX ]'}
                            </span>
                        </div>
                    </div>
                </a>
                
                <div class="flex items-center gap-6">
                    <nav class="hidden md:flex gap-8 text-sm font-bold text-slate-600 dark:text-slate-400">
                        <a href={`/${lang}`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Pokedex</a>
                        <a href={`/${lang}/movimientos`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Movimientos</a>
                        <a href={`/${lang}/habilidades`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">Habilidades</a>
                        <a href={`/${lang}/objetos`} class="hover:text-emerald-500 dark:hover:text-emerald-400 transition-colors">{lang === 'es' ? 'Objetos' : 'Items'}</a>
                    </nav>

                    <div class="flex items-center gap-4 border-l border-slate-200 dark:border-slate-800 pl-6">
                        <!-- SWITCH CON ICONOS SVG VISIBLES -->
                        <button 
                            id="theme-switch"
                            class="relative inline-flex h-9 w-16 items-center rounded-full bg-slate-200 dark:bg-slate-800 transition-colors cursor-pointer shadow-inner group"
                            aria-label="Toggle Theme"
                        >
                            <div class="absolute left-1 h-7 w-7 rounded-full bg-white dark:bg-slate-700 shadow-lg transform transition-all duration-300 flex items-center justify-center z-10 dark:translate-x-7">
                                <!-- Icono Sol -->
                                <svg class="h-4 w-4 text-amber-500 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 9h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a3 3 0 100 6 3 3 0 000-6z" />
                                </svg>
                                <!-- Icono Luna -->
                                <svg class="h-4 w-4 text-emerald-400 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                                </svg>
                            </div>
                        </button>

                        <!-- Pokémon Aleatorio -->
                        <button 
                            id="random-pokemon-btn"
                            class="h-9 w-9 flex items-center justify-center rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-emerald-500 hover:text-white transition-all group"
                            title={lang === 'es' ? 'Pokémon Aleatorio' : 'Random Pokémon'}
                        >
                            <svg class="w-5 h-5 group-hover:rotate-180 transition-transform duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><circle cx="15.5" cy="15.5" r="1.5"/><circle cx="15.5" cy="8.5" r="1.5"/><circle cx="8.5" cy="15.5" r="1.5"/><circle cx="12" cy="12" r="1.5"/>
                            </svg>
                        </button>

                        <a href={otherLangPath} class="h-9 px-4 flex items-center rounded-xl bg-slate-100 dark:bg-slate-800 text-[10px] font-black uppercase tracking-widest transition-all hover:bg-emerald-500 hover:text-white dark:hover:bg-emerald-500">
                            {otherLang}
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <main class="container mx-auto px-4 py-12 flex-grow">
		    <slot />
        </main>

        <footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 py-16 mt-auto">
            <div class="container mx-auto px-4 text-center">
                <div class="mb-8">
                    <a 
                        href="https://buymeacoffee.com/xarli11" 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-3 px-6 py-3 rounded-2xl bg-amber-50 dark:bg-amber-900/10 border border-amber-100 dark:border-amber-900/30 text-amber-600 dark:text-amber-400 font-bold text-sm hover:scale-105 transition-all group"
                    >
                        <svg class="w-5 h-5 group-hover:rotate-12 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
                            <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
                            <line x1="6" y1="1" x2="6" y2="4"></line>
                            <line x1="10" y1="1" x2="10" y2="4"></line>
                            <line x1="14" y1="1" x2="14" y2="4"></line>
                        </svg>
                        {uiTranslations[lang]?.support_project || uiTranslations.es.support_project}
                    </a>
                </div>
                <p class="text-slate-900 dark:text-white font-black text-lg tracking-tight italic">
                    © 2026 Pokepedia <span class="text-emerald-500 mx-2">•</span> Data up to Gen 9
                </p>
                <p class="mt-4 text-slate-500 dark:text-slate-400 text-sm">
                    Created by <span class="text-emerald-600 dark:text-emerald-400 font-black underline decoration-emerald-500/20 underline-offset-8">Xarli11</span>
                </p>
            </div>
        </footer>

        <script is:inline define:vars={{ lang }}>
            function initTheme() {
                const btn = document.getElementById('theme-switch');
                if (!btn) return;
                btn.onclick = () => {
                    const isDark = document.documentElement.classList.toggle('dark');
                    localStorage.setItem('theme', isDark ? 'dark' : 'light');
                };
            }

            function initRandom() {
                const btn = document.getElementById('random-pokemon-btn');
                if (!btn) return;
                btn.onclick = async () => {
                    btn.disabled = true;
                    btn.classList.add('animate-pulse', 'opacity-50');
                    const randomId = Math.floor(Math.random() * 1025) + 1;
                    try {
                        const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${randomId}`);
                        const data = await res.json();
                        window.location.href = `/${lang}/pokemon/${data.name}`;
                    } catch (e) {
                        btn.disabled = false;
                        btn.classList.remove('animate-pulse', 'opacity-50');
                    }
                };
            }

            initTheme();
            initRandom();
            document.addEventListener('astro:after-swap', () => {
                initTheme();
                initRandom();
            });
        </script>
	</body>
</html>
