---
import { formatName, uiTranslations } from '../utils/pokemon';
import TierLegend from './TierLegend.astro';

interface Props {
    pokemonName: string;
    lang: string;
}

const { pokemonName, lang = 'es' } = Astro.props;
const t = uiTranslations[lang] || uiTranslations.es;
---

<div class="mt-12 bg-white dark:bg-slate-800 rounded-[3rem] border border-slate-100 dark:border-slate-700 shadow-xl p-8 md:p-12 transition-colors overflow-hidden relative">
    <div class="absolute -top-12 -right-12 w-48 h-48 bg-emerald-400/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="flex items-center gap-4 mb-10">
        <div class="p-3 bg-emerald-100 dark:bg-emerald-900/30 rounded-2xl text-emerald-600 dark:text-emerald-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <div>
            <h3 class="text-sm font-black text-slate-400 dark:text-slate-500 uppercase tracking-[0.2em]">{t.comp_analysis}</h3>
            <p class="text-2xl font-black text-slate-900 dark:text-white">Smogon Tier & Meta</p>
        </div>
    </div>

    <div id="competitive-content" class="space-y-10" data-pokemon={pokemonName.toLowerCase().replace(/[^a-z0-9]/g, '')} data-lang={lang}>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 animate-pulse">
            <div class="h-32 bg-slate-100 dark:bg-slate-700/50 rounded-3xl"></div>
            <div class="h-32 bg-slate-100 dark:bg-slate-700/50 rounded-3xl"></div>
        </div>
    </div>

    <TierLegend lang={lang} />
</div>

<script is:inline define:vars={{ uiTranslations }}>
    const abilityCache = new Map();

    async function getAbilityInfo(abilityName, lang) {
        const slug = abilityName.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        const psSlug = abilityName.toLowerCase().replace(/[^a-z0-9]/g, '');
        
        if (abilityCache.has(slug)) return abilityCache.get(slug);

        let name = abilityName;
        let desc = "";

        try {
            // 1. Intentar PokeAPI para traducción al español
            const res = await fetch(`https://pokeapi.co/api/v2/ability/${slug}`);
            if (res.ok) {
                const data = await res.json();
                name = data.names.find(n => n.language.name === lang)?.name || 
                       data.names.find(n => n.language.name === 'es')?.name || 
                       name;
                
                const entry = data.flavor_text_entries.find(f => f.language.name === lang) ||
                             data.flavor_text_entries.find(f => f.language.name === 'es') ||
                             data.flavor_text_entries.find(f => f.language.name === 'en');
                
                if (entry) {
                    desc = entry.flavor_text;
                } else {
                    const effect = data.effect_entries.find(e => e.language.name === lang) ||
                                 data.effect_entries.find(e => e.language.name === 'en');
                    desc = effect ? effect.short_effect : "";
                }
            }
        } catch (e) { 
            console.error(`Error fetching ability ${slug}:`, e);
        }

        // 2. FALLBACK: Si no hay descripción o falló la API, mostrar mensaje por defecto
        if (!desc) {
            desc = lang === 'es' ? "Descripción no disponible en este momento." : "Description not available at this moment.";
        }

        const result = { name, desc: (desc || (lang === 'es' ? "Sin descripción disponible." : "No description available.")).replace(/\f/g, ' ') };
        abilityCache.set(slug, result);
        return result;
    }

    async function loadCompetitiveData() {
        const container = document.getElementById('competitive-content');
        if (!container) return;
        const pokemon = container.dataset.pokemon;
        const lang = container.dataset.lang;
        const t = uiTranslations[lang] || uiTranslations.es;

        try {
            if (!window.psPokedex) {
                const res = await fetch('https://play.pokemonshowdown.com/data/pokedex.json');
                if (!res.ok) throw new Error('Failed to fetch Pokedex');
                window.psPokedex = await res.json();
            }

            const data = window.psPokedex[pokemon];
            if (!data) {
                console.warn(`No competitive data found for: ${pokemon}`);
                container.innerHTML = `<p class="text-slate-400 italic text-center py-10">${t.comp_no_data}</p>`;
                return;
            }

            const tier = data.tier || 'Untiered';
            const rawAbilities = data.abilities ? Object.values(data.abilities) : [];
            
            if (rawAbilities.length === 0) {
                 container.innerHTML = `<p class="text-slate-400 italic text-center py-10">${t.comp_no_abilities}</p>`;
                 return;
            }

            const abilitiesInfo = await Promise.all(
                rawAbilities.map(name => getAbilityInfo(name, lang))
            );

            const metaDesc = t.comp_meta_desc
                .replace('{tier}', `<strong>${tier}</strong>`)
                .replace('{abilities}', `<span class="text-emerald-600 dark:text-emerald-400">${abilitiesInfo.map(a => a.name).join(', ')}</span>`);

            container.innerHTML = `
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-6">
                        <div>
                            <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-3">${t.comp_usage}</p>
                            <div class="inline-flex items-center gap-4 bg-slate-50 dark:bg-slate-900/50 px-6 py-3 rounded-2xl border border-slate-100 dark:border-slate-700 shadow-inner">
                                <span class="w-4 h-4 rounded-full bg-emerald-500 shadow-[0_0_12px_rgba(16,185,129,0.6)] animate-pulse"></span>
                                <span class="text-3xl font-black text-slate-900 dark:text-white tracking-tighter">${tier}</span>
                            </div>
                        </div>
                        <div class="bg-emerald-50 dark:bg-emerald-950/20 p-6 rounded-[2rem] border border-emerald-100/50 dark:border-emerald-900/20">
                            <p class="text-xs font-black text-emerald-600 dark:text-emerald-400 uppercase tracking-widest mb-3">${t.comp_meta}</p>
                            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-medium">
                                ${metaDesc}
                            </p>
                            <a href="https://www.smogon.com/dex/sv/pokemon/${pokemon}" target="_blank" class="inline-flex items-center gap-2 mt-5 bg-white dark:bg-slate-900 px-4 py-2 rounded-xl text-emerald-600 dark:text-emerald-400 font-bold text-xs shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all border border-emerald-100 dark:border-emerald-900/30">
                                ${t.comp_smogon_link}
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                            </a>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <p class="text-[10px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest px-2">${t.comp_effects}</p>
                        <div class="space-y-3">
                            ${abilitiesInfo.map(a => `
                                <div class="bg-slate-50 dark:bg-slate-900/40 p-5 rounded-2xl border border-slate-100 dark:border-slate-700/50 group hover:border-emerald-200 dark:hover:border-emerald-800 transition-colors">
                                    <p class="text-sm font-black text-slate-800 dark:text-white mb-1 group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">${a.name}</p>
                                    <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed italic font-medium">${a.desc}</p>
                                </div>
                            `).join('')}
                        </div>
                    </div>
                </div>
            `;
        } catch (e) {
            container.innerHTML = `<p class="text-slate-400 italic">${t.comp_error}</p>`;
        }
    }

    loadCompetitiveData();
    document.addEventListener('astro:after-swap', loadCompetitiveData);
</script>
