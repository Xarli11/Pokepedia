---
import { TIER_DEFINITIONS } from '../services/smogon';

interface Props {
    lang: string;
}

const { lang = 'es' } = Astro.props;
---

<div class="mt-6 bg-slate-50 dark:bg-slate-900/50 rounded-2xl p-6 border border-slate-100 dark:border-slate-800">
    <div class="flex items-center gap-2 mb-4">
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <h4 class="text-xs font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest">Leyenda de Categorías (Tiers)</h4>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {Object.entries(TIER_DEFINITIONS).map(([key, data]) => (
            <div class="flex items-start gap-3 group">
                <span class={`flex-shrink-0 min-w-[2.5rem] px-1.5 text-[8px] font-black text-white ${data.color} h-4 flex items-center justify-center rounded shadow-sm mt-0.5`}>
                    {key}
                </span>
                <div>
                    <p class="text-[10px] font-bold text-slate-700 dark:text-slate-300 leading-none mb-1 group-hover:text-emerald-500 transition-colors">
                        {data.label}
                    </p>
                    <p class="text-[9px] text-slate-400 dark:text-slate-500 leading-tight italic">
                        {data.desc}
                    </p>
                </div>
            </div>
        ))}
    </div>
</div>
