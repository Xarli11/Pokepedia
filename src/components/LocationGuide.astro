---
// src/components/LocationGuide.astro
import { formatName, versionTranslations, encounterTranslations, formatLocationName } from '../utils/pokemon';

interface Props {
    pokemonId: number;
    lang: string;
}

const { pokemonId, lang = 'es' } = Astro.props;
const i18n = encounterTranslations[lang as string] || encounterTranslations.es;

let encounters = [];
try {
    // Las variedades a menudo no tienen encuentros propios, intentamos obtenerlos
    const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${pokemonId}/encounters`);
    if (res.ok) {
        encounters = await res.json();
    }
} catch (e) {
    console.error("Error fetching encounters", e);
}

// Si es una variedad y no tiene encuentros, podríamos intentar los de la especie base, 
// pero usualmente las Megas/G-Max no se encuentran en estado salvaje, así que es correcto que esté vacío.

// Cache para no repetir peticiones
const areaNamesCache = new Map();

const fetchAreaName = async (areaUrl: string, technicalName: string) => {
    if (areaNamesCache.has(areaUrl)) return areaNamesCache.get(areaUrl);
    
    try {
        const areaRes = await fetch(areaUrl);
        if (!areaRes.ok) return formatLocationName(technicalName, lang);
        const areaData = await areaRes.json();
        
        let localized = areaData.names?.find((n: any) => n.language.name === lang)?.name;
        
        if (!localized && areaData.location?.url) {
            const locRes = await fetch(areaData.location.url);
            if (locRes.ok) {
                const locData = await locRes.json();
                localized = locData.names?.find((n: any) => n.language.name === lang)?.name;
            }
        }

        const name = localized || formatLocationName(technicalName, lang);
        areaNamesCache.set(areaUrl, name);
        return name;
    } catch (e) {
        return formatLocationName(technicalName, lang);
    }
};

const groupedEncounters: Record<string, any[]> = {};

const processEncounters = async () => {
    if (!Array.isArray(encounters)) return;
    
    const promises = encounters.map(async (loc: any) => {
        try {
            const areaName = await fetchAreaName(loc.location_area.url, loc.location_area.name);
            
            (loc.version_details || []).forEach((det: any) => {
                const ver = det.version.name;
                if (!groupedEncounters[ver]) groupedEncounters[ver] = [];
                
                if (!groupedEncounters[ver].find(e => e.location === areaName)) {
                    groupedEncounters[ver].push({
                        location: areaName,
                        chance: det.max_chance,
                        method: det.encounter_details[0]?.method?.name || 'walk'
                    });
                }
            });
        } catch (e) {}
    });
    
    await Promise.all(promises);
};

await processEncounters();
const versions = Object.keys(groupedEncounters).reverse();
---

{versions.length > 0 && (
    <div class="mt-20">
        <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-10 px-4 flex items-center gap-4">
            <span class="w-2 h-8 bg-emerald-500 rounded-full shadow-[0_0_15px_rgba(16,185,129,0.4)]"></span>
            {i18n.encounters_title}
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {versions.slice(0, 12).map((v) => (
                <div class="bg-white dark:bg-slate-900 rounded-[2rem] p-6 border border-slate-100 dark:border-slate-800 shadow-sm hover:shadow-xl transition-all duration-300 group">
                    <div class="flex items-center justify-between mb-4 border-b border-slate-50 dark:border-slate-800 pb-4">
                        <span class="text-xs font-black uppercase tracking-widest text-emerald-500">
                            {versionTranslations[v] || formatName(v)}
                        </span>
                        <div class="w-2 h-2 rounded-full bg-slate-200 dark:bg-slate-700"></div>
                    </div>
                    <div class="space-y-4">
                        {groupedEncounters[v].slice(0, 4).map((e) => (
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-slate-700 dark:text-slate-200 capitalize leading-tight">
                                    {e.location}
                                </span>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-[9px] font-black uppercase text-slate-400 bg-slate-50 dark:bg-slate-800 px-2 py-0.5 rounded-md border border-slate-100 dark:border-slate-700">
                                        {i18n.method}: {i18n[e.method] || e.method.replace(/-/g, ' ')}
                                    </span>
                                    <span class="text-[9px] font-black text-emerald-500">
                                        {i18n.chance}: {e.chance}%
                                    </span>
                                </div>
                            </div>
                        ))}
                        {groupedEncounters[v].length > 4 && (
                            <p class="text-[10px] text-slate-400 italic pt-2">
                                + {groupedEncounters[v].length - 4} {i18n.more_areas}
                            </p>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
)}
