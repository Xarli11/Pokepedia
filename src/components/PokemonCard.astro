---
// src/components/PokemonCard.astro
import { typeTranslations, typeColors, formatPokemonNumber } from '../utils/pokemon';
import type { PokemonDetail } from '../services/pokeapi';

interface Props {
    pokemon: PokemonDetail;
    lang: string;
}

const { pokemon, lang = 'es' } = Astro.props;
const typesString = pokemon.types.map(t => t.type.name).join(',');
---

<a 
    href={`/${lang}/pokemon/${pokemon.name}`} 
    class="group relative bg-white dark:bg-slate-900/80 rounded-[2.5rem] p-6 pb-10 border border-slate-200/50 dark:border-slate-800/50 hover:bg-white/80 dark:hover:bg-slate-800/40 hover:backdrop-blur-xl hover:border-emerald-500/50 dark:hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-300 flex flex-col items-center overflow-hidden pokemon-card" 
    data-name={pokemon.name} 
    data-id={pokemon.id} 
    data-types={typesString}
    style="content-visibility: auto; contain-intrinsic-size: 200px 380px; transform: translateZ(0);"
>
    <!-- Botón Favorito -->
    <button 
        class="absolute top-5 right-6 z-30 fav-btn p-2 rounded-xl bg-slate-100/50 dark:bg-slate-900/30 hover:bg-emerald-500/20 transition-all group/fav-btn"
        data-pokemon={pokemon.name}
        onclick="event.preventDefault(); window.toggleFavorite(this.dataset.pokemon)"
        title={lang === 'es' ? 'Añadir a Favoritos' : 'Add to Favorites'}
    >
        <svg class="w-4 h-4 heart-icon transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
    </button>

    <div class="absolute top-5 left-6 flex items-center gap-3 z-20">
        <span class="text-slate-300 dark:text-slate-600 font-black text-[10px] tracking-[0.2em] transition-colors group-hover:text-emerald-500/50">
            {formatPokemonNumber(pokemon.id)}
        </span>
        <div class="tier-badge opacity-80 group-hover:opacity-100 transition-opacity" data-tier-for={pokemon.name.toLowerCase().replace(/[^a-z0-0]/g, '')}>
            <div class="h-4 w-8 bg-slate-100/50 dark:bg-slate-900/30 rounded-lg animate-pulse"></div>
        </div>
    </div>
    
    <div class="relative w-32 h-32 flex items-center justify-center transition-all duration-700 group-hover:scale-110 group-hover:-rotate-3 z-10">

        <!-- Resplandor de fondo al hover -->
        <div class="absolute inset-0 bg-emerald-500/20 blur-[40px] rounded-full opacity-0 group-hover:opacity-40 transition-opacity duration-700"></div>
        
        <img 
            src={pokemon.sprites.other["official-artwork"].front_default} 
            alt={pokemon.name} 
            width="140"
            height="140"
            class="w-full h-full object-contain drop-shadow-xl relative z-20"
            loading="lazy"
            decoding="async"
        />
    </div>
    
    <h2 class="relative mt-6 text-xl font-black text-slate-800 dark:text-white capitalize z-10 group-hover:text-emerald-500 transition-colors tracking-tight">
        {pokemon.name.replace(/-/g, ' ')}
    </h2>
    
    <div class="relative flex gap-2 mt-4 z-10">
        {pokemon.types.map((t) => {
            const typeName = t.type.name;
            const bgColor = typeColors[typeName] || '#777';
            const label = typeTranslations[lang][typeName] || typeName;
            
            return (
                <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-xl bg-white/50 dark:bg-slate-900/40 border border-slate-100/50 dark:border-slate-700/50 shadow-sm transition-transform group-hover:scale-105">
                    <div class="w-1.5 h-1.5 rounded-full" style={`background-color: ${bgColor}; box-shadow: 0 0 8px ${bgColor}88;`}></div>
                    <span class="text-[8px] font-black uppercase tracking-widest text-slate-600 dark:text-slate-400">
                        {label}
                    </span>
                </div>
            );
        })}
    </div>
</a>

<script is:inline>
    // Script Global Único para Tiers
    if (!window.tierScriptInjected) {
        window.tierScriptInjected = true;
        
        async function loadTiers() {
            if (!window.psPokedex) {
                const res = await fetch('https://play.pokemonshowdown.com/data/pokedex.json');
                window.psPokedex = await res.json();
            }
            updateTiers();
        }

        function updateTiers() {
            if (!window.psPokedex) return;
            const colors = {
                'Uber': 'bg-red-500', 'OU': 'bg-emerald-500', 'UU': 'bg-blue-500',
                'RU': 'bg-amber-500', 'NU': 'bg-violet-500', 'PU': 'bg-slate-500',
                'LC': 'bg-pink-500', 'AG': 'bg-slate-900'
            };
            
            document.querySelectorAll('.tier-badge[data-tier-for]').forEach(badge => {
                const name = badge.dataset.tierFor;
                const tier = window.psPokedex[name]?.tier || 'N/A';
                if (tier !== 'N/A') {
                    badge.innerHTML = `<span class="${colors[tier] || 'bg-slate-400'} text-white text-[8px] font-black px-1.5 py-0.5 rounded-md shadow-sm">${tier}</span>`;
                } else {
                    badge.innerHTML = '';
                }
            });
        }

        loadTiers();

        function updateFavButtons() {
            const favorites = JSON.parse(localStorage.getItem('pokepedia_favorites') || '[]');
            document.querySelectorAll('.fav-btn').forEach(btn => {
                const isFav = favorites.includes(btn.dataset.pokemon);
                const heart = btn.querySelector('.heart-icon');
                if (isFav) {
                    heart.setAttribute('fill', 'currentColor');
                    btn.classList.add('text-red-500');
                    btn.classList.remove('text-slate-400');
                } else {
                    heart.setAttribute('fill', 'none');
                    btn.classList.remove('text-red-500');
                    btn.classList.add('text-slate-400');
                }
            });
        }

        updateFavButtons();
        document.addEventListener('astro:after-swap', updateFavButtons);
        document.addEventListener('favorites-updated', updateFavButtons);
    }
</script>
