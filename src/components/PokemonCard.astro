---
// src/components/PokemonCard.astro
import { typeTranslations, typeColors, formatPokemonNumber } from '../utils/pokemon';
import type { PokemonDetail } from '../services/pokeapi';

interface Props {
    pokemon: PokemonDetail;
    lang: string;
}

const { pokemon, lang = 'es' } = Astro.props;
const typesString = pokemon.types.map(t => t.type.name).join(',');
---

<a 
    href={`/${lang}/pokemon/${pokemon.name}`} 
    class="group relative bg-white dark:bg-slate-900/80 rounded-[3rem] p-8 pb-12 border border-slate-200/50 dark:border-slate-800/50 hover:bg-white/80 dark:hover:bg-slate-800/40 hover:backdrop-blur-xl hover:border-emerald-500/50 dark:hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-500 flex flex-col items-center overflow-hidden pokemon-card" 
    data-name={pokemon.name} 
    data-id={pokemon.id} 
    data-types={typesString}
    style="content-visibility: auto; contain-intrinsic-size: 300px 500px; transform: translateZ(0);"
>
    <!-- Barra Superior Técnica (Separada del sprite) -->
    <div class="w-full flex items-center justify-between mb-10 z-30">
        <div class="flex items-center gap-4">
            <span class="text-slate-300 dark:text-slate-600 font-black text-xs tracking-[0.2em] transition-colors group-hover:text-emerald-500/50">
                {formatPokemonNumber(pokemon.id)}
            </span>
            <div class="tier-badge" data-tier-for={pokemon.name.toLowerCase().replace(/[^a-z0-0]/g, '')}>
                <div class="h-5 w-10 bg-slate-100/50 dark:bg-slate-900/30 rounded-lg animate-pulse"></div>
            </div>
            {pokemon.id <= 1025 && (
                <div class="px-1.5 py-0.5 rounded-md bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 text-[8px] font-black uppercase tracking-widest border border-emerald-500/20">M-A</div>
            )}
        </div>

        <button 
            class="fav-btn p-3 rounded-full bg-slate-50 dark:bg-slate-950/40 border border-slate-100/50 dark:border-slate-800/50 hover:bg-rose-500/10 transition-all duration-300 group/fav-btn"
            data-pokemon={pokemon.name}
            onclick="event.preventDefault(); event.stopPropagation(); window.toggleFavorite(this.dataset.pokemon)"
            title={lang === 'es' ? 'Añadir a Favoritos' : 'Add to Favorites'}
        >
            <svg class="w-6 h-6 heart-icon transition-all duration-500 ease-out group-hover/fav-btn:scale-125 group-active/fav-btn:scale-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path>
            </svg>
        </button>
    </div>
    
    <!-- Área del Sprite con Resplandor Expandido -->
    <div class="relative w-56 h-56 flex items-center justify-center transition-all duration-700 group-hover:scale-110 group-hover:-rotate-3 z-10">
        <div class="absolute inset-0 bg-emerald-500/20 blur-[60px] rounded-full opacity-0 group-hover:opacity-60 transition-opacity duration-700"></div>
        
        <img 
            src={pokemon.sprites.other["official-artwork"].front_default} 
            alt={pokemon.name} 
            width="220"
            height="220"
            class="w-full h-full object-contain drop-shadow-2xl relative z-20"
            loading="lazy"
            decoding="async"
        />
    </div>
    
    <h2 class="relative mt-10 text-3xl font-[1000] text-slate-800 dark:text-white capitalize z-10 group-hover:text-emerald-500 transition-colors tracking-tighter text-center">
        {pokemon.name.replace(/-/g, ' ')}
    </h2>
    
    <div class="relative flex gap-3 mt-6 z-10">
        {pokemon.types.map((t) => {
            const typeName = t.type.name;
            const bgColor = typeColors[typeName] || '#777';
            const label = typeTranslations[lang][typeName] || typeName;
            
            return (
                <div class="flex items-center gap-2 px-4 py-2 rounded-xl bg-white/50 dark:bg-slate-900/40 border border-slate-100/50 dark:border-slate-700/50 shadow-sm transition-transform group-hover:scale-105">
                    <div class="w-2 h-2 rounded-full" style={`background-color: ${bgColor}; box-shadow: 0 0 10px ${bgColor}88;`}></div>
                    <span class="text-[10px] font-black uppercase tracking-widest text-slate-600 dark:text-slate-400">
                        {label}
                    </span>
                </div>
            );
        })}
    </div>
</a>

<script is:inline>
    if (!window.tierScriptInjected) {
        window.tierScriptInjected = true;
        
        async function loadTiers() {
            if (!window.psPokedex) {
                const res = await fetch('https://play.pokemonshowdown.com/data/pokedex.json');
                window.psPokedex = await res.json();
            }
            updateTiers();
        }

        function updateTiers() {
            if (!window.psPokedex) return;
            const colors = {
                'Champion': 'bg-gradient-to-r from-yellow-400 to-amber-500 font-bold text-black border border-yellow-600 shadow-sm',
                'Uber': 'bg-red-500', 'OU': 'bg-emerald-500', 'UU': 'bg-blue-500',
                'RU': 'bg-amber-500', 'NU': 'bg-violet-500', 'PU': 'bg-slate-500',
                'LC': 'bg-pink-500', 'AG': 'bg-slate-900'
            };
            
            document.querySelectorAll('.tier-badge[data-tier-for]').forEach(badge => {
                const name = badge.dataset.tierFor;
                const tier = window.psPokedex[name]?.tier || 'N/A';
                if (tier !== 'N/A') {
                    badge.innerHTML = `<span class="${colors[tier] || 'bg-slate-400'} text-white text-[8px] font-black px-1.5 py-0.5 rounded-md shadow-sm ${tier === 'Champion' ? 'text-black' : ''}">${tier}</span>`;
                } else {
                    badge.innerHTML = '';
                }
            });
        }

        loadTiers();

        function updateFavButtons() {
            const favorites = JSON.parse(localStorage.getItem('pokepedia_favorites') || '[]');
            document.querySelectorAll('.fav-btn').forEach(btn => {
                const isFav = favorites.includes(btn.dataset.pokemon);
                const heart = btn.querySelector('.heart-icon');
                const currentlyFav = heart.getAttribute('fill') === 'currentColor';

                if (isFav) {
                    heart.setAttribute('fill', 'currentColor');
                    btn.classList.add('text-rose-500');
                    btn.classList.remove('text-slate-400');
                    // Solo efecto pop si cambia de estado a favorito
                    if (!currentlyFav) {
                        btn.style.transform = 'scale(1.2)';
                        setTimeout(() => btn.style.transform = 'scale(1)', 200);
                    }
                } else {
                    heart.setAttribute('fill', 'none');
                    btn.classList.remove('text-rose-500');
                    btn.classList.add('text-slate-400');
                }
            });
        }

        updateFavButtons();
        document.addEventListener('astro:after-swap', () => {
            updateTiers();
            updateFavButtons();
        });
        document.addEventListener('favorites-updated', updateFavButtons);
    }
</script>
