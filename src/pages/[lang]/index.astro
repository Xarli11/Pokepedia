---
import Layout from '../../layouts/Layout.astro';
import PokemonCard from '../../components/PokemonCard.astro';
import { getPokemonByGeneration, getAllPokemonNames, GENERATIONS } from '../../services/pokeapi';
import { uiTranslations } from '../../utils/pokemon';

const { lang = 'es' } = Astro.params;
const url = new URL(Astro.request.url);
const gen = url.searchParams.get('gen') || 'gen1';

const [pokemonList] = await Promise.all([
    getPokemonByGeneration(gen)
]);

const t = uiTranslations[lang as string] || uiTranslations.es;
---

<Layout title="Pokepedia" lang={lang}>
    <div class="text-center mb-20 max-w-4xl mx-auto mt-12 px-4">
        <h1 class="text-6xl md:text-8xl font-black text-slate-900 dark:text-white mb-8 tracking-tighter">
            {t.desc_hero} <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-500 to-teal-400">Pokémon</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-500 dark:text-slate-400 leading-relaxed font-medium max-w-2xl mx-auto">
            {t.desc_subtitle}
        </p>
    </div>

    <!-- Buscador Global Gris Azulado -->
    <div class="max-w-2xl mx-auto mb-20 relative">
        <div class="relative z-40 group">
            <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none text-slate-400 group-focus-within:text-emerald-500 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <input 
                type="text" 
                id="global-search"
                placeholder={t.search_placeholder} 
                autocomplete="off"
                class="w-full pl-14 pr-6 py-5 rounded-[2rem] bg-white dark:bg-slate-800 border-2 border-slate-100 dark:border-slate-700 text-slate-900 dark:text-white text-lg placeholder-slate-400 focus:outline-none focus:border-emerald-500/50 dark:focus:border-emerald-500/30 shadow-2xl shadow-slate-200/50 dark:shadow-black/40 transition-all duration-300"
            >
        </div>

        <!-- Resultados Autocomplete -->
        <div id="search-suggestions" class="hidden absolute top-full left-0 right-0 mt-4 bg-white/95 dark:bg-slate-800/95 rounded-[2rem] border border-slate-100 dark:border-slate-700 shadow-2xl overflow-hidden z-[100] max-h-[450px] overflow-y-auto backdrop-blur-xl transition-all">
            <div id="suggestions-list" class="divide-y divide-slate-50 dark:divide-slate-700/50">
                <!-- JS -->
            </div>
        </div>
        
        <!-- Selector de Regiones: Lab Terminal Switcher -->
        {gen !== 'favorites' && (
            <div class="mt-12 mb-16 max-w-5xl mx-auto px-4">
                <div class="bg-slate-200/30 dark:bg-slate-900/40 backdrop-blur-md rounded-[2rem] p-1.5 border border-slate-200/50 dark:border-slate-800/50 shadow-inner">
                    <div class="overflow-x-auto no-scrollbar snap-x snap-mandatory flex gap-1 items-center">
                        {Object.entries(GENERATIONS).map(([key, value], index) => (
                            <button 
                                class={`gen-pill snap-center flex-1 min-w-[110px] sm:min-w-0 px-4 py-3 rounded-[1.5rem] transition-all duration-500 flex flex-col items-center gap-0.5 group/pill ${
                                    gen === key 
                                    ? 'bg-white dark:bg-emerald-500 shadow-lg dark:shadow-emerald-500/20 z-10' 
                                    : 'hover:bg-white/50 dark:hover:bg-slate-800/50'
                                }`}
                                data-gen={key}
                            >
                                <span class={`text-[8px] font-mono font-bold tracking-[0.2em] ${
                                    gen === key ? 'text-emerald-500 dark:text-emerald-100' : 'text-slate-400 dark:text-slate-600'
                                }`}>
                                    0{index + 1}
                                </span>
                                <span class={`text-[10px] font-black uppercase tracking-wider ${
                                    gen === key ? 'text-slate-900 dark:text-white' : 'text-slate-500 dark:text-slate-500'
                                }`}>
                                    {value.region}
                                </span>
                            </button>
                        ))}
                    </div>
                </div>
                
                <!-- Indicador de Scroll para Móvil -->
                <div class="flex justify-center gap-1 mt-4 sm:hidden opacity-30">
                    {Object.keys(GENERATIONS).map((key) => (
                        <div class={`h-1 w-1 rounded-full transition-all ${gen === key ? 'w-4 bg-emerald-500 opacity-100' : 'bg-slate-400'}`}></div>
                    ))}
                </div>
            </div>
        )}

        {gen === 'favorites' && (
            <div class="mt-8 mb-16 text-center">
                <div class="inline-flex items-center gap-3 px-6 py-2 rounded-2xl bg-rose-500/10 border border-rose-500/20 text-rose-500 font-black uppercase tracking-[0.2em] text-xs">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path>
                    </svg>
                    {t.favorites}
                </div>
            </div>
        )}
    </div>

    <!-- Grid -->
    <div id="no-results" class="hidden text-center py-20">
        <div class="inline-flex items-center justify-center w-24 h-24 bg-slate-100 dark:bg-slate-800 rounded-full mb-6">
            <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 9.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-800 dark:text-white mb-2">{lang === 'es' ? 'No se encontraron Pokémon' : 'No Pokémon found'}</h3>
        <p class="text-slate-500 dark:text-slate-400">{lang === 'es' ? 'Intenta buscar en las sugerencias o cambiar de región.' : 'Try searching in suggestions or change region.'}</p>
    </div>

    <div id="pokemon-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
        {pokemonList.map((pokemon) => (
            <PokemonCard 
                pokemon={pokemon}
                lang={lang}
            />
        ))}
    </div>

    <script define:vars={{ lang, uiTranslations, gen }}>
        const searchInput = document.getElementById('global-search');
        const suggestionsContainer = document.getElementById('search-suggestions');
        const suggestionsList = document.getElementById('suggestions-list');
        const grid = document.getElementById('pokemon-grid');
        const noResults = document.getElementById('no-results');
        const cards = document.querySelectorAll('.pokemon-card');
        const genPills = document.querySelectorAll('.gen-pill');

        const t = uiTranslations[lang] || uiTranslations.es;

        // Si estamos en la vista de favoritos al cargar
        if (gen === 'favorites') {
            loadFavoritesView();
        }

        async function loadFavoritesView() {
            const favorites = JSON.parse(localStorage.getItem('pokepedia_favorites') || '[]');
            grid.innerHTML = '';
            
            if (favorites.length === 0) {
                noResults.classList.remove('hidden');
                noResults.querySelector('h3').textContent = t.no_favorites;
                noResults.querySelector('p').textContent = '';
                return;
            }

            noResults.classList.add('hidden');
            grid.classList.remove('hidden');

            // Mostrar esqueletos de carga
            grid.innerHTML = Array(6).fill(0).map(() => `
                <div class="h-[400px] bg-white dark:bg-slate-900/50 rounded-[2.5rem] animate-pulse border border-slate-100 dark:border-slate-800"></div>
            `).join('');

            try {
                const pokemonData = await Promise.all(
                    favorites.map(name => fetch(`https://pokeapi.co/api/v2/pokemon/${name}`).then(res => res.json()))
                );

                grid.innerHTML = '';
                pokemonData.forEach(p => {
                    const card = document.createElement('a');
                    card.href = `/${lang}/pokemon/${p.name}`;
                    card.className = "group relative bg-white dark:bg-slate-900/80 rounded-[2.5rem] p-6 pb-10 border border-slate-200/50 dark:border-slate-800/50 hover:bg-white/80 dark:hover:bg-slate-800/40 hover:backdrop-blur-xl hover:border-emerald-500/50 dark:hover:border-emerald-500/30 hover:shadow-2xl hover:shadow-emerald-500/10 transition-all duration-500 flex flex-col items-center overflow-hidden pokemon-card";
                    card.dataset.name = p.name;
                    card.dataset.id = p.id;
                    card.dataset.types = p.types.map(t => t.type.name).join(',');
                    
                    const typeColors = {
                        normal: '#A8A878', fire: '#F08030', water: '#6890F0', electric: '#F8D030', grass: '#78C850',
                        ice: '#98D8D8', fighting: '#C03028', poison: '#A040A0', ground: '#E0C068', flying: '#A890F0',
                        psychic: '#F85888', bug: '#A8B820', rock: '#B8A038', ghost: '#705898', dragon: '#7038F8',
                        dark: '#705848', steel: '#B8B8D0', fairy: '#EE99AC'
                    };

                    const typesHtml = p.types.map(type => `
                        <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-white/50 dark:bg-slate-900/40 border border-slate-100/50 dark:border-slate-700/50 shadow-sm">
                            <div class="w-1.5 h-1.5 rounded-full" style="background-color: ${typeColors[type.type.name] || '#777'};"></div>
                            <span class="text-[9px] font-black uppercase tracking-widest text-slate-600 dark:text-slate-400">${type.type.name}</span>
                        </div>
                    `).join('');

                    card.innerHTML = `
                        <div class="w-full flex items-center justify-between mb-8 z-30">
                            <div class="flex items-center gap-3">
                                <span class="text-slate-300 dark:text-slate-600 font-black text-[10px] tracking-[0.2em] transition-colors group-hover:text-emerald-500/50">#${p.id.toString().padStart(4, '0')}</span>
                                <div class="tier-badge" data-tier-for="${p.name.toLowerCase().replace(/[^a-z0-0]/g, '')}"></div>
                            </div>
                            <button class="fav-btn p-2.5 rounded-full bg-slate-50 dark:bg-slate-950/40 border border-slate-100/50 dark:border-slate-800/50 hover:bg-rose-500/10 transition-all duration-300 group/fav-btn text-rose-500" data-pokemon="${p.name}">
                                <svg class="w-5 h-5 heart-icon transition-all duration-500 ease-out group-hover/fav-btn:scale-125 group-active/fav-btn:scale-90" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="relative w-44 h-44 flex items-center justify-center transition-all duration-700 group-hover:scale-110 group-hover:-rotate-3 z-10">
                            <div class="absolute inset-0 bg-emerald-500/20 blur-[50px] rounded-full opacity-0 group-hover:opacity-60 transition-opacity duration-700"></div>
                            <img src="${p.sprites.other["official-artwork"].front_default}" alt="${p.name}" width="180" height="180" class="w-full h-full object-contain drop-shadow-2xl relative z-20" loading="lazy">
                        </div>
                        <h2 class="relative mt-8 text-2xl font-[1000] text-slate-800 dark:text-white capitalize z-10 group-hover:text-emerald-500 transition-colors tracking-tighter">${p.name.replace(/-/g, ' ')}</h2>
                        <div class="relative flex gap-2 mt-5 z-10">${typesHtml}</div>
                    `;

                    card.querySelector('.fav-btn').onclick = (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        window.toggleFavorite(p.name);
                    };

                    grid.appendChild(card);
                });

                // Reinicializar tiers si es necesario
                if (window.updateTiers) window.updateTiers();

            } catch (e) {
                console.error('Error loading favorites:', e);
            }
        }

        let searchTimeout;

        function normalize(str) {
            return str.toLowerCase().replace(/-/g, ' ').trim();
        }

        async function handleSearch() {
            const query = normalize(searchInput.value);
            const currentCards = document.querySelectorAll('.pokemon-card');
            
            // 1. Filtrar Cuadrícula Local
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(async () => {
                let visibleCount = 0;
                for (let i = 0; i < currentCards.length; i++) {
                    const card = currentCards[i];
                    const name = normalize(card.getAttribute('data-name'));
                    const id = card.getAttribute('data-id');
                    const isVisible = query === '' || name.includes(query) || id.includes(query);
                    card.style.display = isVisible ? 'flex' : 'none';
                    if (isVisible) visibleCount++;
                }
                
                // 2. Sugerencias Globales vía API
                if (query.length >= 2) {
                    // Mostrar Skeletons de Carga
                    suggestionsContainer.classList.remove('hidden');
                    suggestionsList.innerHTML = Array(3).fill(0).map(() => `
                        <div class="flex items-center gap-5 px-6 py-4 animate-pulse">
                            <div class="w-12 h-12 bg-slate-100 dark:bg-slate-700 rounded-2xl"></div>
                            <div class="flex flex-col gap-2">
                                <div class="w-10 h-2 bg-slate-100 dark:bg-slate-700 rounded"></div>
                                <div class="w-24 h-4 bg-slate-100 dark:bg-slate-700 rounded"></div>
                            </div>
                        </div>
                    `).join('');

                    try {
                        const res = await fetch(`/api/suggestions?q=${encodeURIComponent(query)}`);
                        const matches = await res.json();

                        if (matches.length > 0) {
                            suggestionsList.innerHTML = matches.map(p => {
                                const spriteUrl = p.sprite || `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${p.id}.png`;
                                const isVariety = p.id > 10000;
                                
                                return `
                                <a href="/${lang}/pokemon/${p.name}" class="flex items-center gap-5 px-6 py-4 hover:bg-emerald-50 dark:hover:bg-emerald-950/20 transition-colors group">
                                    <div class="w-12 h-12 bg-slate-50 dark:bg-slate-900/50 rounded-2xl flex items-center justify-center p-1 border border-slate-100 dark:border-slate-700/50 group-hover:bg-white dark:group-hover:bg-slate-800 transition-colors shadow-sm">
                                        <img src="${spriteUrl}" alt="${p.name}" class="w-10 h-10 object-contain image-render-pixel" loading="lazy" onerror="this.src='/pokeball.png'; this.classList.add('opacity-20');">
                                    </div>
                                    <div class="flex flex-col">
                                        <span class="text-[10px] font-black text-slate-300 dark:text-slate-600">${isVariety ? t.special_form : '#' + p.id.toString().padStart(4, '0')}</span>
                                        <span class="text-slate-700 dark:text-slate-200 font-bold capitalize group-hover:text-emerald-600 dark:group-hover:text-emerald-400 transition-colors">${p.name.replace(/-/g, ' ')}</span>
                                    </div>
                                    <span class="ml-auto text-[9px] font-black text-slate-400 dark:text-slate-600 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all transform translate-x-2 group-hover:translate-x-0">${lang === 'es' ? 'Ver Ficha' : 'View Info'} →</span>
                                </a>
                            `}).join('');
                        } else {
                            suggestionsContainer.classList.add('hidden');
                        }
                    } catch (e) {
                        console.error('Error fetching suggestions:', e);
                        suggestionsContainer.classList.add('hidden');
                    }
                } else {
                    suggestionsContainer.classList.add('hidden');
                }

                // Mostrar mensaje de "sin resultados" solo si la cuadrícula está vacía y hay una búsqueda
                if (visibleCount === 0 && query.length > 0) {
                    grid.classList.add('hidden');
                    noResults.classList.remove('hidden');
                } else {
                    grid.classList.remove('hidden');
                    noResults.classList.add('hidden');
                }
            }, 100);
        }

        // Atajo de Teclado '/'
        document.addEventListener('keydown', (e) => {
            if (e.key === '/' && document.activeElement !== searchInput) {
                e.preventDefault();
                searchInput.focus();
                window.scrollTo({ top: searchInput.offsetTop - 100, behavior: 'smooth' });
            }
        });

        searchInput.addEventListener('input', handleSearch);
        searchInput.addEventListener('focus', () => {
            if (normalize(searchInput.value).length >= 2) {
                suggestionsContainer.classList.remove('hidden');
            }
        });

        // Tecla Enter para ir al primer resultado
        searchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                const firstResult = suggestionsList.querySelector('a');
                if (firstResult) {
                    window.location.href = firstResult.href;
                }
            }
        });

        document.addEventListener('click', (e) => {
            if (!searchInput.contains(e.target) && !suggestionsContainer.contains(e.target)) {
                suggestionsContainer.classList.add('hidden');
            }
        });

        // Escuchar actualizaciones de favoritos
        document.addEventListener('favorites-updated', () => {
            if (gen === 'favorites') {
                loadFavoritesView();
            }
        });

        genPills.forEach(pill => {
            pill.onclick = () => {
                const url = new URL(window.location.href);
                url.searchParams.set('gen', pill.dataset.gen);
                window.location.href = url.toString();
            };
        });
    </script>
</Layout>
