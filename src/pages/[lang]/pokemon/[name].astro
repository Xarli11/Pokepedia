---
import Layout from '../../../layouts/Layout.astro';
import MovesTable from '../../../components/MovesTable.astro';
import EvolutionChain from '../../../components/EvolutionChain.astro';
import CompetitiveSets from '../../../components/CompetitiveSets.astro';
import LocationGuide from '../../../components/LocationGuide.astro';
import { getPokemonByName, getLocalizedName, getEvolutionChain } from '../../../services/pokeapi';
import { uiTranslations, typeTranslations, typeColors, formatPokemonNumber, formatName, getPoketypesName } from '../../../utils/pokemon';

const { lang, name } = Astro.params;

let pokemonData;
try {
    pokemonData = await getPokemonByName(name as string);
} catch (e) {
    return Astro.redirect(`/${lang}?error=notfound`);
}

const { detail, species } = pokemonData;

// Obtener variedades (Formas alternativas como Megas, G-Max)
const varieties = await Promise.all(
    species.varieties
        .filter((v: any) => !v.is_default)
        .map(async (v: any) => {
            const res = await fetch(v.pokemon.url);
            return res.json();
        })
);

// Obtener cadena evolutiva y traducciones en paralelo
const [evolutionChain, abilitiesWithTranslation] = await Promise.all([
    getEvolutionChain(species.evolution_chain.url),
    Promise.all(
        detail.abilities.map(async (a) => {
            try {
                const res = await fetch(a.ability.url);
                const abilityDetail = await res.json();
                const translatedName = abilityDetail.names.find((n: any) => n.language.name === lang)?.name || formatName(a.ability.name);
                const translatedDesc = abilityDetail.flavor_text_entries.find((f: any) => f.language.name === lang)?.flavor_text.replace(/\f/g, ' ') || 
                                     abilityDetail.flavor_text_entries.find((f: any) => f.language.name === 'en')?.flavor_text.replace(/\f/g, ' ') || "";
                return {
                    ...a,
                    displayName: translatedName,
                    description: translatedDesc
                };
            } catch (e) {
                return { ...a, displayName: formatName(a.ability.name), description: "" };
            }
        })
    )
]);

const t = uiTranslations[lang as string] || uiTranslations.es;
const speciesName = getLocalizedName(species.names, lang as string) || species.name;
let localizedName = speciesName;

// Si el nombre del detalle no es el mismo que el de la especie, es una variedad
if (detail.name !== species.name) {
    const suffix = detail.name.replace(species.name, '').replace(/-/g, ' ').trim();
    if (suffix) {
        // Formatear sufijos comunes
        const suffixMap: Record<string, string> = {
            'gmax': lang === 'es' ? 'Gigamax' : 'G-Max',
            'mega': 'Mega',
            'alola': 'Alola',
            'galar': 'Galar',
            'hisui': 'Hisui',
            'paldea': 'Paldea',
            'mega x': 'Mega X',
            'mega y': 'Mega Y'
        };
        const prettySuffix = suffixMap[suffix.toLowerCase()] || formatName(suffix);
        localizedName = `${speciesName} (${prettySuffix})`;
    }
}

const description = species.flavor_text_entries.find(entry => entry.language.name === lang)?.flavor_text.replace(/\f/g, ' ') || 
                  species.flavor_text_entries.find(entry => entry.language.name === (lang === 'es' ? 'en' : 'es'))?.flavor_text.replace(/\f/g, ' ');

const height = detail.height / 10;
const weight = detail.weight / 10;

const getStatColor = (baseStat: number) => {
    if (baseStat < 70) return 'from-red-400 to-red-600';
    if (baseStat < 100) return 'from-yellow-400 to-yellow-600';
    return 'from-emerald-400 to-emerald-600';
};

const totalStats = detail.stats.reduce((acc, s) => acc + s.base_stat, 0);

// Lógica para Navegación Anterior/Siguiente (Dex Nacional 1-1025)
const currentDexId = detail.id > 10000 ? species.url.split('/').filter(Boolean).pop() : detail.id;
const prevId = Number(currentDexId) === 1 ? 1025 : Number(currentDexId) - 1;
const nextId = Number(currentDexId) === 1025 ? 1 : Number(currentDexId) + 1;

const [prevPokemon, nextPokemon] = await Promise.all([
    fetch(`https://pokeapi.co/api/v2/pokemon/${prevId}`).then(res => res.json()),
    fetch(`https://pokeapi.co/api/v2/pokemon/${nextId}`).then(res => res.json())
]);

// Lógica para el gráfico de radar (SVG)
const statsValues = detail.stats.map(s => s.base_stat);
const angleStep = (Math.PI * 2) / 6;
const radius = 80; // Reducido un poco para dejar espacio a etiquetas
const center = 125;

const points = statsValues.map((stat, i) => {
    const r = (Math.min(stat, 180) / 180) * radius; 
    const x = center + r * Math.sin(i * angleStep);
    const y = center - r * Math.cos(i * angleStep);
    return `${x},${y}`;
}).join(' ');

const statLabels = [t.stat_hp, t.stat_atk, t.stat_def, t.stat_spatk, t.stat_spdef, t.stat_spd];

const gridLevels = [0.25, 0.5, 0.75, 1];
const seoTitle = lang === 'es' 
    ? `${localizedName}: Stats, Debilidades y Estrategia | Pokepedia`
    : `${localizedName}: Stats, Weaknesses & Strategy | Pokepedia`;

const seoDescription = lang === 'es'
    ? `Analiza a ${localizedName}: Stats base (${totalStats}), tipos, debilidades y mejores estrategias competitivas en la Pokepedia técnica definitiva.`
    : `Analyze ${localizedName}: Base stats (${totalStats}), types, weaknesses, and top competitive strategies in the ultimate technical Pokepedia.`;
---

<Layout 
    title={seoTitle} 
    description={seoDescription}
    image={detail.sprites.other["official-artwork"].front_default}
    lang={lang}
>
    <div class="max-w-5xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-12">
            <div class="flex flex-col gap-4">
                <a href={`/${lang}`} class="inline-flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-emerald-500 dark:hover:text-emerald-400 font-bold transition-colors group">
                    <div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 flex items-center justify-center group-hover:border-emerald-500/30 transition-all shadow-sm">
                        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
                    </div>
                    {t.back_to_pokedex}
                </a>
                
                <div class="flex items-center gap-4">
                    <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white capitalize tracking-tighter">
                        {localizedName}
                    </h1>
                    <button 
                        class="fav-btn p-3 rounded-2xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 hover:border-rose-500/30 transition-all shadow-sm group/fav text-slate-400"
                        data-pokemon={name}
                        onclick="window.toggleFavorite(this.dataset.pokemon)"
                        title={lang === 'es' ? 'Añadir a Favoritos' : 'Add to Favorites'}
                    >
                        <svg class="w-6 h-6 heart-icon transition-all duration-300 group-hover/fav:scale-110 group-active/fav:scale-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Navegación Rápida -->
            <div class="flex items-center gap-3">
                <a href={`/${lang}/pokemon/${prevPokemon.name}`} class="flex items-center gap-3 pl-2 pr-4 py-2 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 transition-all group no-underline">
                    <img src={prevPokemon.sprites.front_default} alt={prevPokemon.name} class="w-10 h-10 object-contain image-render-pixel group-hover:scale-110 transition-transform" />
                    <div class="flex flex-col">
                        <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">#{prevId.toString().padStart(4, '0')}</span>
                        <span class="text-xs font-bold text-slate-700 dark:text-slate-200 capitalize group-hover:text-emerald-500 transition-colors leading-none">{prevPokemon.name.replace(/-/g, ' ')}</span>
                    </div>
                </a>

                <div class="w-px h-8 bg-slate-100 dark:bg-slate-800 hidden sm:block"></div>

                <a href={`/${lang}/pokemon/${nextPokemon.name}`} class="flex items-center gap-3 pl-4 pr-2 py-2 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 transition-all group no-underline text-right">
                    <div class="flex flex-col">
                        <span class="text-[9px] font-black text-slate-400 dark:text-slate-500 uppercase tracking-widest leading-none mb-1">#{nextId.toString().padStart(4, '0')}</span>
                        <span class="text-xs font-bold text-slate-700 dark:text-slate-200 capitalize group-hover:text-emerald-500 transition-colors leading-none">{nextPokemon.name.replace(/-/g, ' ')}</span>
                    </div>
                    <img src={nextPokemon.sprites.front_default} alt={nextPokemon.name} class="w-10 h-10 object-contain image-render-pixel group-hover:scale-110 transition-transform" />
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12 items-start">
            <!-- Columna Izquierda: Arte y Tipos -->
            <div class="lg:col-span-5 flex flex-col items-center">
                <div class="relative group w-full aspect-square flex items-center justify-center p-8 bg-white dark:bg-slate-900 rounded-[3rem] border border-slate-100 dark:border-slate-800 shadow-xl shadow-slate-200/50 dark:shadow-none transition-all duration-700 hover:shadow-emerald-500/10 hover:border-emerald-500/20 overflow-hidden">
                    <!-- Resplandor de fondo -->
                    <div class="absolute inset-0 bg-emerald-500/5 dark:bg-emerald-500/10 opacity-0 group-hover:opacity-100 blur-[80px] transition-opacity duration-1000"></div>
                    
                    <button 
                        id="shiny-toggle"
                        class="absolute top-6 right-6 p-2.5 rounded-2xl bg-slate-50 dark:bg-slate-800 text-slate-400 dark:text-slate-500 hover:text-amber-500 dark:hover:text-amber-400 transition-all z-20 group/shiny"
                        title="Ver versión Shiny"
                    >
                        <svg class="w-6 h-6 group-hover/shiny:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4M4 19h4M13 3l.6 2.1c.1.3.4.6.7.7L16.5 6.5l-2.2.6c-.3.1-.6.4-.7.7L13 10l-.6-2.2c-.1-.3-.4-.6-.7-.7L9.5 6.5l2.2-.6c.3-.1.6-.4.7-.7L13 3zM19 13l.3 1.1c.1.2.2.3.4.4l1.1.3-1.1.3c-.2.1-.3.2-.4.4l-.3 1.1-.3-1.1c-.1-.2-.2-.3-.4-.4l-1.1-.3 1.1-.3c.2-.1.3-.2.4-.4l.3-1.1z"></path></svg>
                    </button>

                    <img 
                        id="pokemon-image"
                        src={detail.sprites.other["official-artwork"].front_default} 
                        alt={localizedName} 
                        class="relative w-full h-full object-contain drop-shadow-[0_20px_40px_rgba(0,0,0,0.1)] dark:drop-shadow-[0_20px_40px_rgba(16,185,129,0.15)] transition-all duration-500 z-10"
                        data-default={detail.sprites.other["official-artwork"].front_default}
                        data-shiny={detail.sprites.other["official-artwork"].front_shiny}
                    />
                </div>

                <div class="flex gap-3 mt-8">
                    {detail.types.map(t => (
                        <div 
                            class="px-6 py-2.5 rounded-2xl text-white font-black text-sm uppercase tracking-widest shadow-lg transition-transform hover:scale-105"
                            style={`background-color: ${typeColors[t.type.name]}; box-shadow: 0 10px 20px -5px ${typeColors[t.type.name]}66;`}
                        >
                            {typeTranslations[lang as string][t.type.name]}
                        </div>
                    ))}
                </div>
            </div>

            <!-- Columna Derecha: Stats y Datos -->
            <div class="lg:col-span-7 flex flex-col gap-8">
                <!-- Tarjeta de Info Física -->
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-[2rem] border border-slate-100 dark:border-slate-800 shadow-sm flex items-center gap-4 group hover:border-emerald-500/20 transition-all">
                        <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path></svg>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500">{t.height}</span>
                            <span class="text-xl font-black text-slate-800 dark:text-white leading-none mt-1">{height} m</span>
                        </div>
                    </div>
                    <div class="bg-white dark:bg-slate-900 p-6 rounded-[2rem] border border-slate-100 dark:border-slate-800 shadow-sm flex items-center gap-4 group hover:border-emerald-500/20 transition-all">
                        <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 6l3 12h12l3-12H3z"></path></svg>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 dark:text-slate-500">{t.weight}</span>
                            <span class="text-xl font-black text-slate-800 dark:text-white leading-none mt-1">{weight} kg</span>
                        </div>
                    </div>
                </div>

                <!-- Habilidades -->
                <div class="bg-white dark:bg-slate-900 p-8 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-sm font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-6 flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                        {t.abilities}
                    </h3>
                    <div class="flex flex-col gap-4">
                        {abilitiesWithTranslation.map(a => (
                            <div class="group/ability">
                                <div class="flex items-baseline gap-3 mb-1">
                                    <span class="text-lg font-black text-slate-800 dark:text-white group-hover/ability:text-emerald-500 transition-colors">{a.displayName}</span>
                                    {a.is_hidden && (
                                        <span class="text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-400 dark:text-slate-500">
                                            {t.hidden}
                                        </span>
                                    )}
                                </div>
                                <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed font-medium">{a.description}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Gráfico de Radar de Stats -->
                <div class="bg-white dark:bg-slate-900 p-8 rounded-[2.5rem] border border-slate-100 dark:border-slate-800 shadow-sm relative overflow-hidden">
                    <div class="flex flex-col sm:flex-row items-center gap-8 relative z-10">
                        <!-- Radar SVG -->
                        <div class="relative w-[250px] h-[250px] shrink-0">
                            <svg viewBox="0 0 250 250" class="w-full h-full drop-shadow-2xl">
                                <!-- Rejilla -->
                                {gridLevels.map(level => (
                                    <polygon
                                        points={statLabels.map((_, i) => {
                                            const r = level * radius;
                                            const x = center + r * Math.sin(i * angleStep);
                                            const y = center - r * Math.cos(i * angleStep);
                                            return `${x},${y}`;
                                        }).join(' ')}
                                        class="fill-none stroke-slate-200 dark:stroke-slate-800/50"
                                        stroke-width="1"
                                    />
                                ))}
                                <!-- Ejes -->
                                {statLabels.map((_, i) => {
                                    const x = center + radius * Math.sin(i * angleStep);
                                    const y = center - radius * Math.cos(i * angleStep);
                                    return <line x1={center} y1={center} x2={x} y2={y} class="stroke-slate-200 dark:stroke-slate-800/50" stroke-width="1" />;
                                })}
                                <!-- Polígono de Datos -->
                                <polygon
                                    points={points}
                                    class="fill-emerald-500/30 stroke-emerald-500"
                                    stroke-width="3"
                                    stroke-linejoin="round"
                                />
                                <!-- Puntos -->
                                {points.split(' ').map(p => (
                                    <circle cx={p.split(',')[0]} cy={p.split(',')[1]} r="4" class="fill-white stroke-emerald-500" stroke-width="2" />
                                ))}
                                <!-- Etiquetas -->
                                {statLabels.map((label, i) => {
                                    const r = radius + 25;
                                    const x = center + r * Math.sin(i * angleStep);
                                    const y = center - r * Math.cos(i * angleStep);
                                    return (
                                        <text
                                            x={x}
                                            y={y}
                                            text-anchor="middle"
                                            dominant-baseline="middle"
                                            class="fill-slate-400 dark:fill-slate-500 text-[10px] font-black uppercase tracking-tighter"
                                        >
                                            {label}
                                        </text>
                                    );
                                })}
                            </svg>
                        </div>

                        <!-- Lista de Stats Técnica -->
                        <div class="flex-1 w-full flex flex-col gap-4">
                            <h3 class="text-sm font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-2 flex items-center justify-between">
                                {t.base_stats}
                                <span class="text-emerald-500 font-black">{totalStats} Total</span>
                            </h3>
                            {detail.stats.map(s => (
                                <div class="flex flex-col gap-1.5 group/stat">
                                    <div class="flex justify-between items-baseline px-1">
                                        <span class="text-[10px] font-black uppercase tracking-widest text-slate-500 dark:text-slate-400 group-hover/stat:text-emerald-500 transition-colors">
                                            {t[s.stat.name as keyof typeof t]}
                                        </span>
                                        <span class="text-sm font-black text-slate-800 dark:text-white">{s.base_stat}</span>
                                    </div>
                                    <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                                        <div 
                                            class={`h-full rounded-full bg-gradient-to-r transition-all duration-1000 ${getStatColor(s.base_stat)}`}
                                            style={`width: ${Math.min(s.base_stat, 180) / 1.8}%`}
                                        ></div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {varieties.length > 0 && (
            <div class="mb-12">
                <h3 class="text-sm font-black uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500 mb-6 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                    {t.other_forms}
                </h3>
                <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                    {varieties.map(v => (
                        <a href={`/${lang}/pokemon/${v.name}`} class="bg-white dark:bg-slate-900 p-4 rounded-3xl border border-slate-100 dark:border-slate-800 hover:border-emerald-500/20 hover:shadow-lg transition-all text-center no-underline group">
                            <img src={v.sprites.front_default} alt={v.name} class="w-20 h-20 mx-auto object-contain group-hover:scale-110 transition-transform" />
                            <span class="block text-[10px] font-bold text-slate-600 dark:text-slate-300 mt-2 capitalize">{formatPokemonName(v.name, species.name, lang as string)}</span>
                        </a>
                    ))}
                </div>
            </div>
        )}

        <!-- Cadena Evolutiva -->
        <EvolutionChain chainUrl={species.evolution_chain.url} lang={lang as string} currentName={name as string} />

        <!-- Guía de Localización -->
        <LocationGuide pokemonId={detail.id} lang={lang as string} />

        <!-- Análisis Competitivo -->
        <CompetitiveSets pokemonName={detail.name} lang={lang as string} />

        <!-- Tabla de Movimientos -->
        <MovesTable moves={detail.moves} lang={lang as string} />
    </div>

    <script is:inline>
        function initShiny() {
            const btn = document.getElementById('shiny-toggle');
            const img = document.getElementById('pokemon-image');
            if (!btn || !img) return;

            btn.onclick = () => {
                const isShiny = btn.classList.toggle('active');
                img.style.opacity = '0';
                setTimeout(() => {
                    img.src = isShiny ? img.dataset.shiny : img.dataset.default;
                    img.style.opacity = '1';
                }, 250);
                
                if (isShiny) {
                    btn.classList.add('text-amber-500', 'bg-amber-50', 'dark:bg-amber-900/20');
                } else {
                    btn.classList.remove('text-amber-500', 'bg-amber-50', 'dark:bg-amber-900/20');
                }
            };
        }
        initShiny();
        document.addEventListener('astro:after-swap', initShiny);

        function updateDetailFavButton() {
            const favorites = JSON.parse(localStorage.getItem('pokepedia_favorites') || '[]');
            const btn = document.querySelector('.fav-btn');
            if (btn) {
                const isFav = favorites.includes(btn.dataset.pokemon || '');
                const heart = btn.querySelector('.heart-icon');
                if (isFav) {
                    heart.setAttribute('fill', 'currentColor');
                    btn.classList.add('text-rose-500');
                    btn.classList.remove('text-slate-400');
                    // Efecto pop sutil
                    btn.style.transform = 'scale(1.2)';
                    setTimeout(() => btn.style.transform = 'scale(1)', 200);
                } else {
                    heart.setAttribute('fill', 'none');
                    btn.classList.remove('text-rose-500');
                    btn.classList.add('text-slate-400');
                }
            }
        }

        updateDetailFavButton();
        document.addEventListener('astro:after-swap', updateDetailFavButton);
        document.addEventListener('favorites-updated', updateDetailFavButton);
    </script>
</Layout>
