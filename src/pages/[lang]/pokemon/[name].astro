---
import Layout from '../../../layouts/Layout.astro';
import MovesTable from '../../../components/MovesTable.astro';
import EvolutionChain from '../../../components/EvolutionChain.astro';
import CompetitiveSets from '../../../components/CompetitiveSets.astro';
import { getPokemonByName, getLocalizedName, getEvolutionChain } from '../../../services/pokeapi';
import { getShowdownPokemon } from '../../../services/smogon';
import { uiTranslations, typeTranslations, typeColors, formatPokemonNumber, formatName, getPoketypesName } from '../../../utils/pokemon';
import championsData from '../../../data/champions.json';

const { lang = 'es', name: rawName } = Astro.params;
const name = (rawName as string || '').toLowerCase();

let detail: any = null;
let species: any = null;
let pokemonData: any = null;

try {
    pokemonData = await getPokemonByName(name);
    if (!pokemonData) throw new Error("No data");
    detail = pokemonData.detail;
    species = pokemonData.species;
} catch (e) {
    console.error("Critical error loading pokemon base data:", e);
    return Astro.redirect(`/${lang}`);
}

const isChampionsLegal = championsData.legal_items.some(item => detail.name.includes(item.replace('-stone', ''))) || 
                         detail.id <= 1025 || detail.name.includes('mega');
const recruitmentCost = championsData.recruitment_cost;

// Inicializar arrays para evitar errores de undefined
detail.abilities = detail.abilities || [];
detail.moves = detail.moves || [];
detail.stats = detail.stats || [];
detail.types = detail.types || [];

// 1. Enriquecer con Showdown
try {
    const showdownData = await getShowdownPokemon(name);
    if (showdownData) {
        // Habilidades desde Showdown (Fuente principal de verdad técnica)
        if (showdownData.abilities) {
            detail.abilities = Object.values(showdownData.abilities).map((abilityName: any, index) => ({
                ability: { 
                    name: abilityName.toLowerCase().replace(/\s+/g, '-'), 
                    url: `https://pokeapi.co/api/v2/ability/${abilityName.toLowerCase().replace(/\s+/g, '-')}` 
                },
                is_hidden: index > 0,
                slot: index + 1
            }));
        }

        // Tipos desde Showdown
        if (showdownData.types && showdownData.types.length > 0) {
            detail.types = showdownData.types.map((typeName: string, index: number) => ({
                slot: index + 1,
                type: {
                    name: typeName.toLowerCase(),
                    url: `https://pokeapi.co/api/v2/type/${typeName.toLowerCase()}/`
                }
            }));
        }

        // Stats desde Showdown
        if (showdownData.baseStats) {
            const statMap: Record<string, string> = { hp: 'hp', atk: 'attack', def: 'defense', spa: 'special-attack', spd: 'special-defense', spe: 'speed' };
            detail.stats = detail.stats.map(s => {
                const showdownKey = Object.keys(statMap).find(key => statMap[key] === s.stat.name);
                return { ...s, base_stat: (showdownKey && showdownData.baseStats[showdownKey]) ? showdownData.baseStats[showdownKey] : s.base_stat };
            });
        }
    }
} catch (e) {}

// 2. Fallback de especie (para Movimientos que Showdown no detalla para Megas)
if (detail.moves.length === 0 || detail.abilities.length === 0) {
    const baseVariety = species?.varieties?.find((v: any) => v.is_default);
    if (baseVariety && baseVariety.pokemon.name !== detail.name) {
        try {
            const baseRes = await fetch(baseVariety.pokemon.url);
            if (baseRes.ok) {
                const baseDetail = await baseRes.json();
                if (detail.abilities.length === 0) detail.abilities = baseDetail.abilities || [];
                if (detail.moves.length === 0) detail.moves = baseDetail.moves || [];
            }
        } catch (e) {}
    }
}

// 3. Datos Técnicos
let evolutionChain = null;
let abilitiesWithTranslation = [];
let varieties = [];

try {
    const results = await Promise.allSettled([
        species?.evolution_chain?.url ? getEvolutionChain(species.evolution_chain.url) : Promise.resolve(null),
        Promise.all(detail.abilities.map(async (a: any) => {
            try {
                const res = await fetch(a.ability.url);
                if (!res.ok) throw new Error();
                const ad = await res.json();
                return {
                    ...a,
                    displayName: ad.names?.find((n: any) => n.language.name === lang)?.name || formatName(a.ability.name),
                    description: ad.flavor_text_entries?.find((f: any) => f.language.name === lang)?.flavor_text.replace(/\f/g, ' ') || 
                                 ad.flavor_text_entries?.find((f: any) => f.language.name === 'en')?.flavor_text.replace(/\f/g, ' ') || ""
                };
            } catch (e) {
                return { ...a, displayName: formatName(a.ability.name), description: "" };
            }
        })),
        species?.varieties ? Promise.all(species.varieties.filter((v: any) => !v.is_default).map((v: any) => fetch(v.pokemon.url).then(r => r.ok ? r.json() : null))) : Promise.resolve([])
    ]);

    evolutionChain = results[0].status === 'fulfilled' ? results[0].value : null;
    abilitiesWithTranslation = results[1].status === 'fulfilled' ? results[1].value : [];
    varieties = (results[2].status === 'fulfilled' ? (results[2].value as any[]) : []).filter(Boolean);
} catch (e) {}

const t = uiTranslations[lang as string] || uiTranslations.es;
const speciesName = species ? (getLocalizedName(species.names, lang as string) || species.name) : detail.name;
let localizedName = speciesName;

if (species && detail.name !== species.name) {
    const suffix = detail.name.replace(species.name, '').replace(/-/g, ' ').trim();
    if (suffix) {
        const suffixMap: Record<string, string> = {
            'gmax': lang === 'es' ? 'Gigamax' : 'G-Max', 'mega': 'Mega', 'alola': 'Alola', 'galar': 'Galar', 'hisui': 'Hisui', 'paldea': 'Paldea', 'mega x': 'Mega X', 'mega y': 'Mega Y'
        };
        localizedName = `${speciesName} (${suffixMap[suffix.toLowerCase()] || formatName(suffix)})`;
    }
}

const description = species?.flavor_text_entries?.find((entry: any) => entry.language.name === lang)?.flavor_text.replace(/\f/g, ' ') || 
                  species?.flavor_text_entries?.find((entry: any) => entry.language.name === (lang === 'es' ? 'en' : 'es'))?.flavor_text.replace(/\f/g, ' ') || "";

const pokemonId = detail.id;
const officialArtwork = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${pokemonId}.png`;
const officialArtworkShiny = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/shiny/${pokemonId}.png`;

const height = detail.height / 10;
const weight = detail.weight / 10;
const totalStats = detail.stats.reduce((acc: number, s: any) => acc + s.base_stat, 0);

// Lógica para Navegación Anterior/Siguiente (Dex Nacional 1-1025)
// Obtenemos el ID de la especie desde la URL vinculada en el detalle
const speciesUrl = detail.species?.url || '';
const speciesIdMatch = speciesUrl.match(/\/pokemon-species\/(\d+)\//);
const currentDexId = pokemonId > 10000 ? (speciesIdMatch ? speciesIdMatch[1] : pokemonId) : pokemonId;
const prevId = Number(currentDexId) === 1 ? 1025 : Number(currentDexId) - 1;
const nextId = Number(currentDexId) === 1025 ? 1 : Number(currentDexId) + 1;

let prevPokemon: any = null;
let nextPokemon: any = null;
try {
    const navResults = await Promise.all([
        fetch(`https://pokeapi.co/api/v2/pokemon/${prevId}`).then(res => res.ok ? res.json() : null),
        fetch(`https://pokeapi.co/api/v2/pokemon/${nextId}`).then(res => res.ok ? res.json() : null)
    ]);
    prevPokemon = navResults[0];
    nextPokemon = navResults[1];
} catch (e) {}

const hasNavigation = prevPokemon && nextPokemon;

const statsValues = detail.stats.map((s: any) => s.base_stat);
const angleStep = (Math.PI * 2) / 6;
const radius = 80;
const center = 125;
const points = statsValues.map((stat: number, i: number) => {
    const r = (Math.min(stat, 180) / 180) * radius; 
    const x = center + r * Math.sin(i * angleStep);
    const y = center - r * Math.cos(i * angleStep);
    return `${x},${y}`;
}).join(' ');

const statLabels = [t.stat_hp, t.stat_atk, t.stat_def, t.stat_spatk, t.stat_spdef, t.stat_spd];
const gridLevels = [0.25, 0.5, 0.75, 1];
const seoTitle = `${localizedName}: Stats, Debilidades y Estrategia | Pokepedia`;
const seoDescription = `Analiza a ${localizedName}: Stats base (${totalStats}), tipos, debilidades y estrategias competitivas.`;

const getStatColor = (baseStat: number) => {
    if (baseStat < 70) return 'from-red-400 to-red-600';
    if (baseStat < 100) return 'from-yellow-400 to-yellow-600';
    return 'from-emerald-400 to-emerald-600';
};
---

<Layout title={seoTitle} description={seoDescription} image={officialArtwork} lang={lang as string}>
    <div class="max-w-5xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-12">
            <div class="flex flex-col gap-4">
                <a href={`/${lang}`} class="inline-flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-emerald-500 font-bold transition-colors group">
                    <div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 flex items-center justify-center group-hover:border-emerald-500/30 shadow-sm">
                        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                    </div>
                    {t.back_to_pokedex}
                </a>
                <div class="flex items-center gap-4">
                    <h1 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white capitalize tracking-tighter">{localizedName}</h1>
                    <button class="fav-btn p-3 rounded-2xl bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 text-slate-400" data-pokemon={name} onclick="window.toggleFavorite(this.dataset.pokemon)">
                        <svg class="w-6 h-6 heart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"></path></svg>
                    </button>
                </div>
            </div>

            <div class="flex items-center gap-3">
                {hasNavigation ? (
                    <>
                        <a href={`/${lang}/pokemon/${prevPokemon.name}`} class="flex items-center gap-3 pl-2 pr-4 py-2 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl group no-underline">
                            <img src={prevPokemon.sprites?.front_default} alt="" class="w-10 h-10 object-contain group-hover:scale-110 transition-transform" />
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">#{prevId.toString().padStart(4, '0')}</span>
                                <span class="text-xs font-bold text-slate-700 dark:text-slate-200 capitalize leading-none">{prevPokemon.name.replace(/-/g, ' ')}</span>
                            </div>
                        </a>
                        <div class="w-px h-8 bg-slate-100 dark:bg-slate-800 hidden sm:block"></div>
                        <a href={`/${lang}/pokemon/${nextPokemon.name}`} class="flex items-center gap-3 pl-4 pr-2 py-2 bg-white dark:bg-slate-900 border border-slate-100 dark:border-slate-800 rounded-2xl group no-underline text-right">
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">#{nextId.toString().padStart(4, '0')}</span>
                                <span class="text-xs font-bold text-slate-700 dark:text-slate-200 capitalize leading-none">{nextPokemon.name.replace(/-/g, ' ')}</span>
                            </div>
                            <img src={nextPokemon.sprites?.front_default} alt="" class="w-10 h-10 object-contain group-hover:scale-110 transition-transform" />
                        </a>
                    </>
                ) : <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest bg-slate-100 dark:bg-slate-800 px-4 py-2 rounded-xl">{t.navigation_unavailable || 'Navigation unavailable'}</div>}
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
            <div class="md:col-span-5 flex flex-col items-center">
                <div class="relative w-full aspect-square bg-white dark:bg-slate-900 rounded-[3rem] shadow-xl border border-slate-100 dark:border-slate-800 flex items-center justify-center p-12 mb-8">
                    <img id="pokemon-image" src={officialArtwork} data-default={officialArtwork} data-shiny={officialArtworkShiny} alt={localizedName} class="w-full h-full object-contain drop-shadow-2xl transition-all duration-500" />
                    <span class="absolute top-8 right-8 text-2xl font-black text-slate-200 dark:text-slate-800">{formatPokemonNumber(pokemonId)}</span>
                    <button id="shiny-toggle" class="absolute bottom-6 right-6 p-3 bg-white dark:bg-slate-800 rounded-2xl shadow-lg border border-slate-100 text-slate-400 hover:text-amber-500 transition-all"><svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg></button>
                </div>
                <div class="w-full bg-white dark:bg-slate-900 rounded-3xl p-8 border border-slate-100 dark:border-slate-800 shadow-sm">
                    <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6">{t.basic_info}</h3>
                    <div class="grid grid-cols-2 gap-6">
                        <div><p class="text-slate-400 text-xs font-bold uppercase mb-1">{t.height}</p><p class="text-slate-900 dark:text-white font-bold text-lg">{height} m</p></div>
                        <div><p class="text-slate-400 text-xs font-bold uppercase mb-1">{t.weight}</p><p class="text-slate-900 dark:text-white font-bold text-lg">{weight} kg</p></div>
                        <div class="col-span-2 border-t border-slate-50 dark:border-slate-800 pt-6 mt-2">
                            <p class="text-slate-400 text-xs font-bold uppercase mb-1">{t.abilities}</p>
                            <div class="space-y-3 mt-3">
                                {abilitiesWithTranslation.map((a: any) => (
                                    <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-4 border border-slate-100 dark:border-slate-700">
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class={`text-sm font-bold ${a.is_hidden ? 'text-slate-500' : 'text-emerald-600 dark:text-emerald-400'}`}>{a.displayName}</span>
                                            {a.is_hidden && <span class="text-[10px] font-bold uppercase tracking-widest bg-slate-200 dark:bg-slate-700 text-slate-500 px-2 py-0.5 rounded-md">{t.hidden}</span>}
                                        </div>
                                        <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed italic">{a.description}</p>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full bg-white dark:bg-slate-900 rounded-3xl p-8 border border-slate-100 dark:border-slate-800 shadow-sm mt-8 bg-gradient-to-br from-white to-slate-50 dark:from-slate-900 dark:to-slate-800/50">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest">Pokémon Champions</h3>
                        {isChampionsLegal && (
                            <span class="px-2 py-1 rounded-lg bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 text-[10px] font-black uppercase tracking-widest border border-emerald-500/20">Legal M-A</span>
                        )}
                    </div>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-4 bg-white dark:bg-slate-900 rounded-2xl border border-slate-100 dark:border-slate-800">
                            <div class="flex flex-col">
                                <span class="text-slate-400 text-[10px] font-bold uppercase mb-0.5">{lang === 'es' ? 'Coste Reclutamiento' : 'Recruitment Cost'}</span>
                                <span class="text-slate-900 dark:text-white font-black text-xl tracking-tighter">{recruitmentCost.toLocaleString()} VP</span>
                            </div>
                            <div class="w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center text-amber-500 border border-amber-400/20">
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                            </div>
                        </div>
                        <p class="text-[11px] text-slate-500 dark:text-slate-400 leading-relaxed px-1">
                            {lang === 'es' 
                                ? 'Este Pokémon está disponible en el pool diario de reclutamiento por un coste fijo de VP.' 
                                : 'This Pokémon is available in the daily recruitment pool for a fixed VP cost.'}
                        </p>
                    </div>
                </div>
            </div>

            <div class="md:col-span-7 space-y-12">
                <div class="flex flex-wrap items-center gap-4 mb-6">
                    <div class="flex gap-2">
                        {detail.types.map((t2: any) => (
                            <span class="px-4 py-1.5 rounded-xl text-xs font-black uppercase tracking-widest text-white shadow-sm" style={`background-color: ${typeColors[t2.type.name]}`}>{typeTranslations[lang as string][t2.type.name]}</span>
                        ))}
                    </div>
                    <a href={`https://www.poketypes.app/?t1=${detail.types[0]?.type.name}${detail.types[1] ? `&t2=${detail.types[1].type.name}` : ''}&p=${getPoketypesName(detail.name)}`} target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center gap-3 px-5 py-2 rounded-xl bg-emerald-500/10 border-2 border-emerald-500/20 hover:border-emerald-500 transition-all no-underline">
                        <span class="text-[10px] font-black text-emerald-600 dark:text-emerald-400 uppercase tracking-widest">{lang === 'es' ? 'Análisis de Debilidades' : 'Weakness Analysis'}</span>
                    </a>
                </div>
                <h1 class="text-5xl md:text-6xl font-black text-slate-900 dark:text-white capitalize mb-4">{localizedName}</h1>
                <p class="text-xl text-slate-600 dark:text-slate-400 leading-relaxed italic">"{description}"</p>

                <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] p-10 border border-slate-100 dark:border-slate-800 shadow-sm mb-12">
                    <div class="flex justify-between items-center mb-10"><h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest">{t.base_stats}</h3><div class="flex items-center gap-2"><span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">{t.total}</span><span class="text-2xl font-black text-slate-900 dark:text-white tracking-tighter">{totalStats}</span></div></div>
                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
                        <div class="lg:col-span-5 relative flex justify-center">
                            <svg viewBox="0 0 250 250" class="w-full max-w-[280px] drop-shadow-2xl overflow-visible">
                                {gridLevels.map(level => (
                                    <polygon points={Array.from({length: 6}).map((_, i) => { const r = level * radius; const x = center + r * Math.sin(i * angleStep); const y = center - r * Math.cos(i * angleStep); return `${x},${y}`; }).join(' ')} class="fill-none stroke-slate-200 dark:stroke-slate-800" stroke-width="1" />
                                ))}
                                {Array.from({length: 6}).map((_, i) => (
                                    <line x1={center} y1={center} x2={center + radius * Math.sin(i * angleStep)} y2={center - radius * Math.cos(i * angleStep)} class="stroke-slate-200 dark:stroke-slate-800" stroke-width="1" />
                                ))}
                                {statLabels.map((label, i) => { 
                                    const r = radius + 25; 
                                    const x = center + r * Math.sin(i * angleStep); 
                                    const y = center - r * Math.cos(i * angleStep); 
                                    return <text x={x} y={y} text-anchor="middle" dominant-baseline="middle" class="fill-slate-400 dark:fill-slate-500 text-[10px] font-black tracking-tighter">{label}</text>; 
                                })}
                                <polygon points={points} class="fill-emerald-500/20 stroke-emerald-500" stroke-width="3" stroke-linejoin="round" />
                                {points.split(' ').map((p: string) => (
                                    <circle cx={p.split(',')[0]} cy={p.split(',')[1]} r="3" class="fill-emerald-500" />
                                ))}
                            </svg>
                        </div>
                        <div class="lg:col-span-7 space-y-4">
                            {detail.stats.map((s: any) => { 
                                const percentage = (s.base_stat / 255) * 100; 
                                const colorClass = getStatColor(s.base_stat); 
                                return (
                                    <div>
                                        <div class="flex justify-between mb-1 text-sm font-bold"><span class="text-slate-500 dark:text-slate-400 uppercase tracking-wider">{t[s.stat.name] || s.stat.name}</span><span class="text-slate-900 dark:text-white">{s.base_stat}</span></div>
                                        <div class="w-full bg-slate-100 dark:bg-slate-800 rounded-full h-2 overflow-hidden"><div class={`h-full rounded-full transition-all duration-1000 bg-gradient-to-r ${colorClass}`} style={`width: ${percentage}%`}></div></div>
                                    </div>
                                ); 
                            })}
                        </div>
                    </div>
                </div>

                {varieties && varieties.length > 0 && (
                    <div class="bg-white dark:bg-slate-900 rounded-[2.5rem] p-10 border border-slate-100 dark:border-slate-800 shadow-sm">
                        <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-8">{t.other_forms}</h3>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
                            {varieties.map((v: any) => (
                                <a href={`/${lang}/pokemon/${v.name}`} class="flex flex-col items-center p-6 bg-slate-50 dark:bg-slate-800/50 rounded-3xl border border-slate-100 dark:border-slate-700 hover:border-emerald-500 transition-all group no-underline">
                                    <img src={v.sprites?.other?.["official-artwork"]?.front_default || v.sprites?.front_default} alt={v.name} class="w-24 h-24 object-contain mb-3 drop-shadow-md group-hover:scale-110 transition-transform" />
                                    <span class="text-[11px] font-black text-slate-700 dark:text-slate-200 text-center capitalize tracking-tight">{v.name.replace(/-/g, ' ')}</span>
                                </a>
                            ))}
                        </div>
                    </div>
                )}
            </div>
        </div>

        {evolutionChain && <EvolutionChain chain={evolutionChain} lang={lang as string} />}
        <CompetitiveSets pokemonName={detail.name} lang={lang as string} />
        <MovesTable moves={detail.moves} lang={lang as string} />
    </div>

    <script is:inline>
        function initShiny() {
            const btn = document.getElementById('shiny-toggle');
            const img = document.getElementById('pokemon-image');
            if (!btn || !img) return;
            btn.onclick = () => {
                const isShiny = btn.classList.toggle('active');
                img.style.opacity = '0';
                setTimeout(() => { 
                    img.src = isShiny ? img.dataset.shiny : img.dataset.default; 
                    img.style.opacity = '1'; 
                }, 250);
            };
        }
        initShiny();
        document.addEventListener('astro:after-swap', initShiny);
    </script>
</Layout>
