---
import Layout from '../../../layouts/Layout.astro';
import PokemonCard from '../../../components/PokemonCard.astro';
import { getLocalizedName } from '../../../services/pokeapi';
import { uiTranslations, formatName, typeTranslations, typeColors } from '../../../utils/pokemon';

const { lang, name } = Astro.params;

let moveData;
try {
    const res = await fetch(`https://pokeapi.co/api/v2/move/${name}`);
    if (!res.ok) throw new Error();
    moveData = await res.json();
} catch (e) {
    return Astro.redirect(`/${lang}/movimientos`);
}

const localizedName = getLocalizedName(moveData.names, lang as string) || formatName(moveData.name);
const description = moveData.flavor_text_entries.find((f: any) => f.language.name === lang)?.flavor_text.replace(/\f/g, ' ') || 
                  moveData.flavor_text_entries.find((f: any) => f.language.name === 'en')?.flavor_text.replace(/\f/g, ' ') || "";

const pokemonPromises = moveData.learned_by_pokemon.slice(0, 40).map(async (p: any) => {
    const res = await fetch(p.url);
    return res.json();
});
const pokemonList = await Promise.all(pokemonPromises);

const t = uiTranslations[lang as string] || uiTranslations.es;

const categoryColors: Record<string, string> = {
    physical: 'bg-orange-500',
    special: 'bg-indigo-500',
    status: 'bg-slate-400'
};

const categoryLabels: Record<string, string> = {
    physical: lang === 'es' ? '💪 Físico' : '💪 Physical',
    special: lang === 'es' ? '🔮 Especial' : '🔮 Special',
    status: lang === 'es' ? '✨ Estado' : '✨ Status'
};
---

<Layout title={`${localizedName} | Pokepedia`} lang={lang}>
    <div class="max-w-5xl mx-auto">
        <a href={`/${lang}/movimientos`} class="inline-flex items-center gap-2 text-slate-500 dark:text-slate-400 hover:text-emerald-500 dark:hover:text-emerald-400 font-medium transition-colors mb-8 group">
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
            {t.back_to_moves}
        </a>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
            <!-- Cabecera y Descripción -->
            <div class="md:col-span-8">
                <div class="bg-white dark:bg-slate-800 rounded-[3.5rem] p-10 md:p-14 border border-slate-100 dark:border-slate-700 shadow-2xl shadow-slate-200/50 dark:shadow-black/50 h-full transition-colors duration-300">
                    <div class="flex flex-wrap items-center gap-3 mb-8">
                        <span class="px-5 py-2 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] text-white shadow-lg" style={`background-color: ${typeColors[moveData.type.name]}`}>
                            {typeTranslations[lang as string][moveData.type.name]}
                        </span>
                        <span class={`${categoryColors[moveData.damage_class.name]} text-white px-5 py-2 rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] shadow-lg`}>
                            {categoryLabels[moveData.damage_class.name]}
                        </span>
                    </div>
                    <h1 class="text-6xl font-black text-slate-900 dark:text-white mb-8 capitalize leading-tight tracking-tighter">{localizedName}</h1>
                    <div class="bg-emerald-50/50 dark:bg-emerald-950/10 rounded-3xl p-8 border border-emerald-100/50 dark:border-emerald-900/20">
                        <p class="text-xl text-slate-700 dark:text-slate-300 leading-relaxed italic font-medium">
                            "{description}"
                        </p>
                    </div>
                </div>
            </div>

            <!-- Panel de Datos Técnicos -->
            <div class="md:col-span-4">
                <div class="bg-emerald-600 dark:bg-emerald-500 rounded-[3.5rem] p-10 shadow-2xl shadow-emerald-200 dark:shadow-black/50 h-full flex flex-col justify-between text-white transition-all duration-300">
                    <div class="space-y-8">
                        <div class="flex justify-between items-end border-b border-emerald-500/30 pb-4">
                            <div>
                                <p class="text-emerald-100/70 text-[10px] font-black uppercase tracking-widest mb-1">Potencia</p>
                                <p class="text-4xl font-black">{moveData.power || '—'}</p>
                            </div>
                            <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-sm">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                            </div>
                        </div>
                        <div class="flex justify-between items-end border-b border-emerald-500/30 pb-4">
                            <div>
                                <p class="text-emerald-100/70 text-[10px] font-black uppercase tracking-widest mb-1">Precisión</p>
                                <p class="text-4xl font-black">{moveData.accuracy ? `${moveData.accuracy}%` : '—'}</p>
                            </div>
                            <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-sm">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                        </div>
                        <div class="flex justify-between items-end border-b border-emerald-500/30 pb-4">
                            <div>
                                <p class="text-emerald-100/70 text-[10px] font-black uppercase tracking-widest mb-1">Prioridad</p>
                                <p class={`text-4xl font-black ${moveData.priority > 0 ? 'text-white' : moveData.priority < 0 ? 'text-rose-200' : 'text-emerald-100'}`}>
                                    {moveData.priority > 0 ? `+${moveData.priority}` : moveData.priority}
                                </p>
                            </div>
                            <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-sm">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            </div>
                        </div>
                        <div class="flex justify-between items-end border-b border-emerald-500/30 pb-4">
                            <div>
                                <p class="text-emerald-100/70 text-[10px] font-black uppercase tracking-widest mb-1">PP</p>
                                <p class="text-4xl font-black">{moveData.pp}</p>
                            </div>
                            <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-sm">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="text-3xl font-black text-slate-900 dark:text-white mb-10 px-4 flex items-center gap-4">
            <span class="w-2 h-8 bg-emerald-500 rounded-full"></span>
            {t.pokemon_with_move}
            <span class="text-sm font-bold text-slate-400 dark:text-slate-600 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full border border-slate-200/50 dark:border-slate-700">{pokemonList.length}</span>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
            {pokemonList.map((pokemon) => (
                <PokemonCard pokemon={pokemon} lang={lang as string} />
            ))}
        </div>
    </div>
</Layout>
